{# l2vni.j2 — ios-xe #}
! L2 VNI (VXLAN)
! Intent: {{ intent_id }}
!
vlan {{ vlan_id }}
 name {{ vlan_name | default("VLAN" ~ vlan_id) }}
!
l2vpn evpn instance {{ evi | default(vlan_id) }} vlan-based
 rd {{ rd | default("auto") }}
 route-target export {{ rt_export | default("auto") }}
 route-target import {{ rt_import | default("auto") }}
!
bridge-domain {{ vlan_id }}
 member vni {{ vni_id }}
 member evpn-instance {{ evi | default(vlan_id) }}
!

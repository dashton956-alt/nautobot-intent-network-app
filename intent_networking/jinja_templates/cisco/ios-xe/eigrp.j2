{# eigrp.j2 — ios-xe #}
! EIGRP Configuration
! Intent: {{ intent_id }}
!
{% if named_mode | default(false) %}
router eigrp {{ eigrp_name }}
 address-family ipv4 unicast autonomous-system {{ asn }}
{% for net in networks | default([]) %}
  network {{ net.network }} {{ net.wildcard }}
{% endfor %}
{% if stub | default(false) %}
  eigrp stub {{ stub_options | default("connected summary") }}
{% endif %}
 exit-address-family
{% else %}
router eigrp {{ asn }}
{% for net in networks | default([]) %}
 network {{ net.network }} {{ net.wildcard }}
{% endfor %}
{% if stub | default(false) %}
 eigrp stub {{ stub_options | default("connected summary") }}
{% endif %}
{% endif %}
!

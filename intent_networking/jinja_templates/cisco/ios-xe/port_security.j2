{# port_security.j2 — ios-xe #}
! Port Security
! Intent: {{ intent_id }}
!
{% for iface in interfaces | default([]) %}
interface {{ iface }}
 switchport port-security
{% if max_mac | default("") %}
 switchport port-security maximum {{ max_mac }}
{% endif %}
{% if violation_action | default("") %}
 switchport port-security violation {{ violation_action }}
{% endif %}
{% if sticky | default(false) %}
 switchport port-security mac-address sticky
{% endif %}
{% endfor %}
!

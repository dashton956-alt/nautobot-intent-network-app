{# stp.j2 — ios-xe #}
! STP Configuration
! Intent: {{ intent_id }}
!
spanning-tree mode {{ mode | default("rapid-pvst") }}
{% if bpdu_guard_default | default(false) %}
spanning-tree portfast bpduguard default
{% endif %}
{% if portfast_default | default(false) %}
spanning-tree portfast default
{% endif %}
{% for vlan in vlans | default([]) %}
spanning-tree vlan {{ vlan.id }} priority {{ vlan.priority | default(32768) }}
{% endfor %}
!

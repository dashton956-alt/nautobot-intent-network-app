{# pvlan.j2 — ios-xe #}
! Private VLAN
! Intent: {{ intent_id }}
!
{% if primary_vlan | default("") %}
vlan {{ primary_vlan }}
 private-vlan primary
{% if community_vlans | default([]) %}
 private-vlan association {{ community_vlans | join(',') }}
{% endif %}
{% endif %}
{% for cv in community_vlans | default([]) %}
vlan {{ cv }}
 private-vlan community
{% endfor %}
{% for iv in isolated_vlans | default([]) %}
vlan {{ iv }}
 private-vlan isolated
{% endfor %}
!

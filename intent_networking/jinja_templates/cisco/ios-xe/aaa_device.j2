{# aaa_device.j2 — ios-xe — device-management AAA (TACACS+/RADIUS) #}
! AAA (device management)
! Intent: {{ intent_id }}
!
aaa new-model
!
{% for s in tacacs_servers | default([]) %}
tacacs server TACACS-{{ s.host | default(s.ip) }}
 address ipv4 {{ s.host | default(s.ip) }}
 port {{ s.port | default(49) }}
{% if s.key_ref | default(s.key) %}
 key {{ s.key_ref | default(s.key) }}
{% endif %}
{% if s.timeout is defined %}
 timeout {{ s.timeout }}
{% endif %}
{% endfor %}
{% if server_group %}
!
aaa group server tacacs+ {{ server_group }}
{% for s in tacacs_servers | default([]) %}
 server name TACACS-{{ s.host | default(s.ip) }}
{% endfor %}
{% endif %}
!
{% for method, value in (authentication | default({})).items() %}
aaa authentication {{ method | replace('_', ' ') }} default {{ value }}
{% endfor %}
{% for kind, value in (authorization | default({})).items() %}
aaa authorization {{ kind | replace('_', ' ') }} default {{ value }}
{% endfor %}
{% for kind, value in (accounting | default({})).items() %}
aaa accounting {{ kind | replace('_', ' ') }} default {{ value }}
{% endfor %}
{% if local_fallback %}
!
username {{ local_fallback.username | default('admin') }} privilege {{ local_fallback.privilege | default(15) }} secret {{ local_fallback.password_ref | default('CHANGEME') }}
{% endif %}
!

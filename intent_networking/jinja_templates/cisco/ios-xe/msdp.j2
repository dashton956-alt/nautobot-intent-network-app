{# msdp.j2 — ios-xe #}
! MSDP
! Intent: {{ intent_id }}
!
ip msdp originator-id {{ originator_id }}
{% for peer in peers | default([]) %}
ip msdp peer {{ peer.ip }} connect-source {{ peer.connect_source | default("Loopback0") }} remote-as {{ peer.remote_as }}
{% if peer.sa_limit | default("") %}
ip msdp sa-limit {{ peer.ip }} {{ peer.sa_limit }}
{% endif %}
{% endfor %}
{% if default_peer | default("") %}
ip msdp default-peer {{ default_peer }}
{% endif %}
!

{# anycast_gateway.j2 — ios-xe #}
! Anycast Gateway
! Intent: {{ intent_id }}
!
interface Vlan{{ vlan_id }}
 ip address {{ ip_address }} {{ subnet_mask | default("255.255.255.0") }}
{% if description | default("") %}
 description {{ description }}
{% endif %}
{% if vrf | default("") %}
 vrf forwarding {{ vrf }}
{% endif %}
 standby {{ group_id | default(1) }} ip {{ virtual_ip }}
 standby {{ group_id | default(1) }} priority {{ priority | default(110) }}
 standby {{ group_id | default(1) }} preempt
!

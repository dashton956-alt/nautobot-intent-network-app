{# bgp_ipv6_af.j2 — ios-xe #}
! BGP IPv6 Address Family
! Intent: {{ intent_id }}
!
router bgp {{ local_asn }}
 address-family ipv6 unicast
{% for neighbor in neighbors | default([]) %}
  neighbor {{ neighbor.ip }} activate
{% if neighbor.route_map_in | default("") %}
  neighbor {{ neighbor.ip }} route-map {{ neighbor.route_map_in }} in
{% endif %}
{% if neighbor.route_map_out | default("") %}
  neighbor {{ neighbor.ip }} route-map {{ neighbor.route_map_out }} out
{% endif %}
{% endfor %}
 exit-address-family
!

{# telemetry.j2 — ios-xe #}
! Streaming Telemetry Configuration
! Intent: {{ intent_id }}
!
{% for sub in subscriptions %}
telemetry ietf subscription {{ sub.id | default(loop.index + 100) }}
 encoding encode-{{ encoding | default("kvgpb") }}
 filter xpath {{ sub.path }}
 stream yang-push
 update-policy periodic {{ sub.interval | default(3000) }}
 receiver ip address {{ destination_ip }} {{ destination_port | default(57000) }} protocol {{ protocol | default("grpc-tcp") }}
!
{% endfor %}

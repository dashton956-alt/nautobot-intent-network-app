{# vtep.j2 — ios-xe #}
! VTEP / NVE Interface
! Intent: {{ intent_id }}
!
interface nve1
 no shutdown
 host-reachability protocol bgp
 source-interface {{ source_interface | default("Loopback1") }}
{% for vni in vnis | default([]) %}
 member vni {{ vni.id }}
{% if vni.mcast_group | default("") %}
  mcast-group {{ vni.mcast_group }}
{% endif %}
{% if vni.ingress_replication | default(false) %}
  ingress-replication bgp
{% endif %}
{% endfor %}
!

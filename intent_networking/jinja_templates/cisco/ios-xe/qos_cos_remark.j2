{# qos_cos_remark.j2 — ios-xe #}
! QoS CoS Remark
! Intent: {{ intent_id }}
!
{% for entry in cos_map | default([]) %}
table-map COS-TO-DSCP
 map from {{ entry.cos }} to {{ entry.dscp }}
{% endfor %}
!
policy-map {{ policy_map | default("COS-REMARK") }}
 class class-default
  set dscp dscp table COS-TO-DSCP
!
{% for iface in apply_interfaces | default([]) %}
interface {{ iface }}
 service-policy input {{ policy_map | default("COS-REMARK") }}
{% endfor %}
!

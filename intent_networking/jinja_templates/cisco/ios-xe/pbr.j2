{# pbr.j2 — ios-xe #}
! Policy-Based Routing
! Intent: {{ intent_id }}
!
{% for entry in entries | default([]) %}
route-map {{ route_map_name }} permit {{ entry.sequence | default(loop.index * 10) }}
{% if entry.match_acl | default("") %}
 match ip address {{ entry.match_acl }}
{% endif %}
{% if entry.set_next_hop | default("") %}
 set ip next-hop {{ entry.set_next_hop }}
{% endif %}
{% if entry.set_interface | default("") %}
 set interface {{ entry.set_interface }}
{% endif %}
{% endfor %}
!
{% for iface in apply_interfaces | default([]) %}
interface {{ iface }}
 ip policy route-map {{ route_map_name }}
{% endfor %}
!

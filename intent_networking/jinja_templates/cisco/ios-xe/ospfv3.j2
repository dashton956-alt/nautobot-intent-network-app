{# ospfv3.j2 — ios-xe #}
! OSPFv3 Configuration
! Intent: {{ intent_id }}
!
router ospfv3 {{ process_id }}
{% if router_id | default("") %}
 router-id {{ router_id }}
{% endif %}
 address-family ipv6 unicast
{% for net in networks | default([]) %}
  area {{ net.area }}
{% endfor %}
 exit-address-family
!
{% for iface in interfaces | default([]) %}
interface {{ iface.name }}
 ospfv3 {{ process_id }} ipv6 area {{ iface.area | default("0") }}
{% endfor %}
!

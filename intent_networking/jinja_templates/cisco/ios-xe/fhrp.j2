{# fhrp.j2 — ios-xe #}
! FHRP Configuration
! Intent: {{ intent_id }}
!
{% for group in groups | default([]) %}
interface {{ group.interface }}
{% if protocol | default("hsrp") == "hsrp" %}
 standby {{ group.group_id }} ip {{ group.virtual_ip }}
 standby {{ group.group_id }} priority {{ group.priority | default(100) }}
{% if group.preempt | default(false) %}
 standby {{ group.group_id }} preempt
{% endif %}
{% if group.track | default("") %}
 standby {{ group.group_id }} track {{ group.track }} decrement {{ group.decrement | default(10) }}
{% endif %}
{% elif protocol == "vrrp" %}
 vrrp {{ group.group_id }} ip {{ group.virtual_ip }}
 vrrp {{ group.group_id }} priority {{ group.priority | default(100) }}
{% if group.preempt | default(false) %}
 vrrp {{ group.group_id }} preempt
{% endif %}
{% elif protocol == "glbp" %}
 glbp {{ group.group_id }} ip {{ group.virtual_ip }}
 glbp {{ group.group_id }} priority {{ group.priority | default(100) }}
{% if group.preempt | default(false) %}
 glbp {{ group.group_id }} preempt
{% endif %}
{% endif %}
{% endfor %}
!

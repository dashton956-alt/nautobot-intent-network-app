{# evpn_mpls.j2 — ios-xe #}
! EVPN over MPLS
! Intent: {{ intent_id }}
!
l2vpn evpn
 replication-type {{ replication_type | default("ingress") }}
!
l2vpn evpn instance {{ evi }} vlan-based
 rd {{ rd | default("auto") }}
 route-target export {{ rt_export | default("auto") }}
 route-target import {{ rt_import | default("auto") }}
!
bridge-domain {{ bridge_domain | default(evi) }}
 member evpn-instance {{ evi }}
!

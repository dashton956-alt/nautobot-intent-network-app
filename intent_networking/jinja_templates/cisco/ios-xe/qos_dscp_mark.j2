{# qos_dscp_mark.j2 — ios-xe #}
! QoS DSCP Marking
! Intent: {{ intent_id }}
!
policy-map {{ policy_map }}
{% for m in markings | default([]) %}
 class {{ m.class_name }}
  set dscp {{ m.dscp }}
{% endfor %}
!
{% for iface in apply_interfaces | default([]) %}
interface {{ iface }}
 service-policy input {{ policy_map }}
{% endfor %}
!

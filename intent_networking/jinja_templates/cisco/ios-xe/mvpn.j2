{# mvpn.j2 — ios-xe #}
! MVPN Configuration
! Intent: {{ intent_id }}
!
ip multicast-routing vrf {{ vrf }}
!
vrf definition {{ vrf }}
 address-family ipv4
  mdt default {{ mdt_default_group }}
{% if mdt_data_group | default("") %}
  mdt data {{ mdt_data_group }} threshold {{ mdt_data_threshold | default(0) }}
{% endif %}
 exit-address-family
!

{# qinq.j2 — ios-xe #}
! Q-in-Q / 802.1ad
! Intent: {{ intent_id }}
!
{% if dot1q_tunnel_ethertype | default("") %}
system dot1q-tunnel ethertype {{ dot1q_tunnel_ethertype }}
{% endif %}
!
interface {{ interface }}
 switchport mode dot1q-tunnel
 switchport access vlan {{ outer_vlan }}
{% if l2protocol_tunnel | default(false) %}
 l2protocol-tunnel cdp
 l2protocol-tunnel stp
 l2protocol-tunnel vtp
{% endif %}
!

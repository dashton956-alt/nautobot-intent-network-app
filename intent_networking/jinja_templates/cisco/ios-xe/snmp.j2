{# snmp.j2 — ios-xe #}
! SNMP Configuration
! Intent: {{ intent_id }}
!
{% if location %}
snmp-server location {{ location }}
{% endif %}
{% if contact %}
snmp-server contact {{ contact }}
{% endif %}
{% if version == "v3" %}
{% for view in views %}
snmp-server view {{ view.name }} {{ view.oid }} included
{% endfor %}
{% for group in groups %}
snmp-server group {{ group.name }} v3 {{ group.security_level | default("priv") }}{% if group.read_view %} read {{ group.read_view }}{% endif %}{% if group.write_view %} write {{ group.write_view }}{% endif %}

{% endfor %}
{% for user in users %}
snmp-server user {{ user.name }} {{ user.group }} v3 auth {{ user.auth_protocol | default("sha") }} {{ user.auth_password }} priv {{ user.priv_protocol | default("aes") }} 128 {{ user.priv_password }}
{% endfor %}
{% elif version == "v2c" %}
{% if community %}
snmp-server community {{ community }} ro
{% endif %}
{% endif %}
{% for target in trap_targets %}
snmp-server host {{ target }}{% if version == "v3" %} version 3 priv{% elif community %} version 2c {{ community }}{% endif %}

{% endfor %}
snmp-server enable traps
!

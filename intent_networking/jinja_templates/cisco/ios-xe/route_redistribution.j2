{# route_redistribution.j2 — ios-xe #}
! Route Redistribution
! Intent: {{ intent_id }}
!
{% if target_protocol == "ospf" %}
router ospf {{ target_process_id }}
{% for source in sources | default([]) %}
 redistribute {{ source.protocol }}{% if source.process_id | default("") %} {{ source.process_id }}{% endif %}{% if source.route_map | default("") %} route-map {{ source.route_map }}{% endif %} subnets
{% endfor %}
{% elif target_protocol == "bgp" %}
router bgp {{ target_asn }}
 address-family ipv4 unicast
{% for source in sources | default([]) %}
  redistribute {{ source.protocol }}{% if source.process_id | default("") %} {{ source.process_id }}{% endif %}{% if source.route_map | default("") %} route-map {{ source.route_map }}{% endif %}

{% endfor %}
 exit-address-family
{% elif target_protocol == "eigrp" %}
router eigrp {{ target_asn }}
{% for source in sources | default([]) %}
 redistribute {{ source.protocol }}{% if source.process_id | default("") %} {{ source.process_id }}{% endif %}{% if source.route_map | default("") %} route-map {{ source.route_map }}{% endif %}

{% endfor %}
{% endif %}
!

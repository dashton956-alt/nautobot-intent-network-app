{# lldp_cdp.j2 — ios-xe #}
! LLDP / CDP Configuration
! Intent: {{ intent_id }}
!
{% if lldp_global %}
lldp run
{% else %}
no lldp run
{% endif %}
{% if cdp_global %}
cdp run
{% else %}
no cdp run
{% endif %}
{% for intf in disable_on %}
interface {{ intf }}
 no lldp transmit
 no lldp receive
 no cdp enable
{% endfor %}
!

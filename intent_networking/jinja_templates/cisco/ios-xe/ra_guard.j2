{# ra_guard.j2 — ios-xe #}
! IPv6 RA Guard
! Intent: {{ intent_id }}
!
{% for policy in policies | default([]) %}
ipv6 nd raguard policy {{ policy.name }}
 device-role {{ policy.device_role | default("host") }}
{% endfor %}
!
{% for iface in interfaces | default([]) %}
interface {{ iface.name }}
 ipv6 nd raguard attach-policy {{ iface.policy }}
{% endfor %}
!

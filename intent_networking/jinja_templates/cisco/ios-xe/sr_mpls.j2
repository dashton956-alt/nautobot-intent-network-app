{# sr_mpls.j2 — ios-xe #}
! Segment Routing MPLS
! Intent: {{ intent_id }}
!
segment-routing mpls
 global-block {{ srgb_start | default(16000) }} {{ srgb_end | default(23999) }}
 connected-prefix-sid-map
{% for prefix in prefix_sids | default([]) %}
  address-family ipv4
   {{ prefix.prefix }}/{{ prefix.mask_len | default(32) }} index {{ prefix.index }} range 1
  exit-address-family
{% endfor %}
!
router isis {{ process_tag | default("CORE") }}
 segment-routing mpls
 segment-routing prefix-sid-map advertise-local
!
{% for iface in interfaces | default([]) %}
interface {{ iface }}
 ip router isis {{ process_tag | default("CORE") }}
{% endfor %}
!

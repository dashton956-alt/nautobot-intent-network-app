{# qos_classify.j2 — ios-xe #}
! QoS Classification
! Intent: {{ intent_id }}
!
{% for cm in class_maps | default([]) %}
class-map match-any {{ cm.name }}
{% if cm.dscp | default("") %}
 match dscp {{ cm.dscp }}
{% endif %}
{% if cm.acl | default("") %}
 match access-group name {{ cm.acl }}
{% endif %}
{% if cm.cos | default("") %}
 match cos {{ cm.cos }}
{% endif %}
{% if cm.protocol | default("") %}
 match protocol {{ cm.protocol }}
{% endif %}
{% endfor %}
!
policy-map {{ policy_map }}
{% for cm in class_maps | default([]) %}
 class {{ cm.name }}
{% if cm.set_dscp | default("") %}
  set dscp {{ cm.set_dscp }}
{% endif %}
{% if cm.police_rate | default("") %}
  police {{ cm.police_rate }} conform-action transmit exceed-action drop
{% endif %}
{% endfor %}
!
{% for iface in apply_interfaces | default([]) %}
interface {{ iface }}
 service-policy input {{ policy_map }}
{% endfor %}
!

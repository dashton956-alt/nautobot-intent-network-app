{# storm_control.j2 — ios-xe #}
! Storm Control
! Intent: {{ intent_id }}
!
{% for iface in interfaces | default([]) %}
interface {{ iface }}
{% if broadcast_level | default("") %}
 storm-control broadcast level {{ broadcast_level }}
{% endif %}
{% if multicast_level | default("") %}
 storm-control multicast level {{ multicast_level }}
{% endif %}
{% if unicast_level | default("") %}
 storm-control unicast level {{ unicast_level }}
{% endif %}
{% if action | default("") %}
 storm-control action {{ action }}
{% endif %}
{% endfor %}
!

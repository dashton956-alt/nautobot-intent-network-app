{# ldp.j2 — ios-xe #}
! LDP Configuration
! Intent: {{ intent_id }}
!
mpls ldp router-id {{ router_id_interface | default("Loopback0") }} force
{% if password | default("") %}
mpls ldp password required
{% for neighbor in neighbors | default([]) %}
mpls ldp neighbor {{ neighbor.ip }} password {{ password }}
{% endfor %}
{% endif %}
!
{% for iface in interfaces | default([]) %}
interface {{ iface }}
 mpls ip
{% endfor %}
!

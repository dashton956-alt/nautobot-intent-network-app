{# gre_tunnel.j2 — ios-xe #}
! GRE Tunnel
! Intent: {{ intent_id }}
!
interface Tunnel{{ tunnel_id }}
{% if description | default("") %}
 description {{ description }}
{% endif %}
 ip address {{ tunnel_ip }} {{ tunnel_mask | default("255.255.255.252") }}
 tunnel source {{ tunnel_source }}
 tunnel destination {{ tunnel_destination }}
{% if tunnel_key | default("") %}
 tunnel key {{ tunnel_key }}
{% endif %}
{% if ipsec_profile | default("") %}
 tunnel protection ipsec profile {{ ipsec_profile }}
{% endif %}
{% if keepalive | default(false) %}
 keepalive {{ keepalive_interval | default(10) }} {{ keepalive_retries | default(3) }}
{% endif %}
 ip mtu {{ mtu | default(1400) }}
 ip tcp adjust-mss {{ tcp_mss | default(1360) }}
!

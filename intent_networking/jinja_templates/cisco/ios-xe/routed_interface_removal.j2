{# routed_interface_removal.j2 — ios-xe #}
! Remove Routed (L3) Interface config
! Intent: {{ intent_id }}
!
{% for iface in interfaces | default([]) %}
interface {{ iface.name }}
{% if iface.ip_address %}
 no ip address
{% endif %}
{% if iface.vrf %}
 no vrf forwarding {{ iface.vrf }}
{% endif %}
 switchport
!
{% endfor %}

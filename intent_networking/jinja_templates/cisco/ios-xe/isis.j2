{# isis.j2 — ios-xe #}
! IS-IS Configuration
! Intent: {{ intent_id }}
!
router isis {{ process_tag }}
 net {{ net }}
 is-type {{ is_type | default("level-2-only") }}
{% if metric_style | default("") %}
 metric-style {{ metric_style }}
{% endif %}
{% for passive in passive_interfaces | default([]) %}
 passive-interface {{ passive }}
{% endfor %}
!
{% for iface in interfaces | default([]) %}
interface {{ iface.name }}
 ip router isis {{ process_tag }}
{% if iface.metric | default("") %}
 isis metric {{ iface.metric }}
{% endif %}
{% if iface.network_type | default("") %}
 isis network {{ iface.network_type }}
{% endif %}
{% endfor %}
!

{# bgp_network.j2 — ios-xe #}
! BGP Network Advertisement
! Intent: {{ intent_id }}
!
router bgp {{ local_asn }}
{% if vrf | default("") %}
 address-family ipv4 vrf {{ vrf }}
{% else %}
 address-family ipv4 unicast
{% endif %}
{% for net in networks | default([]) %}
  network {{ net.prefix }}{% if net.mask | default("") %} mask {{ net.mask }}{% endif %}{% if net.route_map | default("") %} route-map {{ net.route_map }}{% endif %}

{% endfor %}
 exit-address-family
!

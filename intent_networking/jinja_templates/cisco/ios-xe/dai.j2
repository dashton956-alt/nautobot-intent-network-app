{# dai.j2 — ios-xe #}
! Dynamic ARP Inspection
! Intent: {{ intent_id }}
!
{% for vlan in vlans | default([]) %}
ip arp inspection vlan {{ vlan }}
{% endfor %}
{% for iface in trusted_interfaces | default([]) %}
interface {{ iface }}
 ip arp inspection trust
{% endfor %}
{% if rate_limit | default("") %}
{% for iface in rate_limited_interfaces | default([]) %}
interface {{ iface }}
 ip arp inspection limit rate {{ rate_limit }}
{% endfor %}
{% endif %}
!

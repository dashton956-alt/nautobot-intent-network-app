{# aaa.j2 — ios-xe #}
! AAA Configuration
! Intent: {{ intent_id }}
!
aaa new-model
!
aaa authentication login default {{ auth_methods | default("local") }}
{% if enable_auth %}
aaa authentication enable default {{ enable_auth }}
{% endif %}
{% if authorization %}
aaa authorization exec default {{ authorization }}
aaa authorization commands 15 default {{ authorization }}
{% endif %}
{% if accounting %}
aaa accounting exec default start-stop {{ accounting }}
aaa accounting commands 15 default start-stop {{ accounting }}
{% endif %}
!
{% for server in radius_servers | default([]) %}
radius server RADIUS-{{ loop.index }}
 address ipv4 {{ server.ip | default(server.host) }} auth-port {{ server.port | default(1812) }}
{% if server.key %}
 key {{ server.key }}
{% endif %}
{% endfor %}
{% for server in tacacs_servers | default([]) %}
tacacs server TACACS-{{ loop.index }}
 address ipv4 {{ server.ip | default(server.host) }}
 port {{ server.port | default(49) }}
{% if server.key %}
 key {{ server.key }}
{% endif %}
{% endfor %}
!

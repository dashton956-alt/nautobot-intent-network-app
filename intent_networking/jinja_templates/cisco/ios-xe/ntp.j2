{# ntp.j2 — ios-xe #}
! NTP Configuration
! Intent: {{ intent_id }}
!
{% if source_interface %}
ntp source {{ source_interface }}
{% endif %}
{% if authentication %}
ntp authenticate
{% endif %}
{% for server in servers %}
{% if server == prefer %}
ntp server {{ server }} prefer
{% else %}
ntp server {{ server }}
{% endif %}
{% endfor %}
!

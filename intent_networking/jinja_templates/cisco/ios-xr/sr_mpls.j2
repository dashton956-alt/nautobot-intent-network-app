{# sr_mpls.j2 — ios-xr #}
! Segment Routing MPLS
! Intent: {{ intent_id }}
!
segment-routing
 global-block {{ srgb_start | default(16000) }} {{ srgb_end | default(23999) }}
!
router isis {{ process_tag | default("CORE") }}
 address-family ipv4 unicast
  segment-routing mpls
{% for prefix in prefix_sids | default([]) %}
 interface {{ prefix.interface | default("Loopback0") }}
  address-family ipv4 unicast
   prefix-sid index {{ prefix.index }}
{% endfor %}
!

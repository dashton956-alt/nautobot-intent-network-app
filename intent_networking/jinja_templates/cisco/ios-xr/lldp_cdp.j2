{# lldp_cdp.j2 — ios-xr #}
! LLDP Configuration
! Intent: {{ intent_id }}
!
{% if lldp_global | default(true) %}
lldp
{% else %}
no lldp
{% endif %}
{% if cdp_global | default(false) %}
cdp
{% endif %}
{% for iface in disable_on | default([]) %}
interface {{ iface }}
 lldp
  transmit disable
  receive disable
{% endfor %}
!

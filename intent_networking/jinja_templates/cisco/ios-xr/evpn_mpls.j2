{# evpn_mpls.j2 — ios-xr #}
! EVPN over MPLS
! Intent: {{ intent_id }}
!
evpn
 evi {{ evi }}
  bgp
   rd {{ rd | default("auto") }}
   route-target import {{ rt_import | default("auto") }}
   route-target export {{ rt_export | default("auto") }}
  advertise-mac
!
l2vpn
 bridge group {{ bridge_group | default("EVPN-BG") }}
  bridge-domain {{ bridge_domain | default("BD-" ~ evi) }}
   evi {{ evi }}
!

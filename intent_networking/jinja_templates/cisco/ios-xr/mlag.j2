{# mlag.j2 — ios-xr #}
! MC-LAG (IOS-XR)
! Intent: {{ intent_id }}
!
redundancy
 iccp
  group {{ iccp_group | default(1) }}
   member
    neighbor {{ peer_ip }}
   backbone
{% for iface in backbone_interfaces | default([]) %}
    interface {{ iface }}
{% endfor %}
!
{% for bundle in bundles | default([]) %}
interface Bundle-Ether{{ bundle.id }}
 mac-address {{ bundle.system_mac | default("") }}
 lacp system-mac {{ bundle.system_mac | default("") }}
 mlacp iccp-group {{ iccp_group | default(1) }}
{% endfor %}
!

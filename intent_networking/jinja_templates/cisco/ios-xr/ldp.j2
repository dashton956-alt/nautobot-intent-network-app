{# ldp.j2 — ios-xr #}
! LDP Configuration
! Intent: {{ intent_id }}
!
mpls ldp
 router-id {{ router_id | default("") }}
{% for iface in interfaces | default([]) %}
 interface {{ iface }}
{% endfor %}
{% if password | default("") %}
{% for neighbor in neighbors | default([]) %}
 neighbor {{ neighbor.ip }}
  password clear {{ password }}
{% endfor %}
{% endif %}
!

{# msdp.j2 — ios-xr #}
! MSDP Configuration
! Intent: {{ intent_id }}
!
router msdp
 originator-id {{ originator_id }}
{% for peer in peers | default([]) %}
 peer {{ peer.ip }}
  connect-source {{ peer.connect_source | default("Loopback0") }}
  remote-as {{ peer.remote_as }}
{% if peer.sa_limit | default("") %}
  sa-limit {{ peer.sa_limit }}
{% endif %}
{% endfor %}
{% if default_peer | default("") %}
 default-peer {{ default_peer }}
{% endif %}
!

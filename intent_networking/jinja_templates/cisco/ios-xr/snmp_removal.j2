{# snmp_removal.j2 — ios-xr #}
! Remove SNMP
! Intent: {{ intent_id }}
!
{% for target in trap_targets | default([]) %}
no snmp-server host {{ target }}
{% endfor %}
{% if community | default("") %}
no snmp-server community {{ community }}
{% endif %}
no snmp-server location
no snmp-server contact
!

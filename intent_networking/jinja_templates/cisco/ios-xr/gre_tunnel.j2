{# gre_tunnel.j2 — ios-xr #}
! GRE Tunnel
! Intent: {{ intent_id }}
!
interface tunnel-ip{{ tunnel_id }}
{% if description | default("") %}
 description {{ description }}
{% endif %}
 ipv4 address {{ tunnel_ip }} {{ tunnel_mask | default("255.255.255.252") }}
 tunnel source {{ tunnel_source }}
 tunnel destination {{ tunnel_destination }}
{% if tunnel_key | default("") %}
 tunnel key {{ tunnel_key }}
{% endif %}
 ipv4 mtu {{ mtu | default(1400) }}
!

{# l2vpn_vpls.j2 — ios-xr #}
! L2VPN VPLS
! Intent: {{ intent_id }}
!
l2vpn
 bridge group {{ bridge_group | default("BG1") }}
  bridge-domain {{ bridge_domain | default("BD1") }}
{% for peer in peers | default([]) %}
   neighbor {{ peer.ip }} pw-id {{ peer.pw_id }}
{% endfor %}
{% if vfi_name | default("") %}
   vfi {{ vfi_name }}
    vpn-id {{ vpn_id }}
    autodiscovery bgp
     rd {{ rd | default("auto") }}
     route-target {{ rt | default("auto") }}
     signaling-protocol ldp
{% endif %}
!

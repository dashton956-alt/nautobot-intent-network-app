{# route_redistribution.j2 — ios-xr #}
! Route Redistribution
! Intent: {{ intent_id }}
!
{% if target_protocol == "ospf" %}
router ospf {{ target_process_id }}
 address-family ipv4 unicast
{% for source in sources | default([]) %}
  redistribute {{ source.protocol }}{% if source.process_id | default("") %} {{ source.process_id }}{% endif %}{% if source.route_policy | default("") %} route-policy {{ source.route_policy }}{% endif %}

{% endfor %}
{% elif target_protocol == "bgp" %}
router bgp {{ target_asn }}
 address-family ipv4 unicast
{% for source in sources | default([]) %}
  redistribute {{ source.protocol }}{% if source.process_id | default("") %} {{ source.process_id }}{% endif %}{% if source.route_policy | default("") %} route-policy {{ source.route_policy }}{% endif %}

{% endfor %}
{% elif target_protocol == "isis" %}
router isis {{ target_process_tag }}
 address-family ipv4 unicast
{% for source in sources | default([]) %}
  redistribute {{ source.protocol }}{% if source.route_policy | default("") %} route-policy {{ source.route_policy }}{% endif %}

{% endfor %}
{% endif %}
!

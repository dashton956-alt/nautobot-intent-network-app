{# dhcp_pool.j2 — ios-xr #}
! DHCP Pool
! Intent: {{ intent_id }}
!
dhcp ipv4
 profile {{ pool_name }} server
  network {{ network }}
{% if default_router | default("") %}
  default-router {{ default_router }}
{% endif %}
{% if dns_server | default("") %}
  dns-server {{ dns_server }}
{% endif %}
  lease {{ lease_days | default(1) }} {{ lease_hours | default(0) }} {{ lease_minutes | default(0) }}
!

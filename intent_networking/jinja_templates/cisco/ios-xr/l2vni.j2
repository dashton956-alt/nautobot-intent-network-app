{# l2vni.j2 — ios-xr #}
! L2 VNI (VXLAN)
! Intent: {{ intent_id }}
!
l2vpn
 bridge group {{ bridge_group | default("VXLAN-BG") }}
  bridge-domain {{ bridge_domain | default("BD-" ~ vlan_id) }}
   member vni {{ vni_id }}
!
evpn
 evi {{ evi | default(vlan_id) }}
  bgp
   rd {{ rd | default("auto") }}
   route-target import {{ rt_import | default("auto") }}
   route-target export {{ rt_export | default("auto") }}
!

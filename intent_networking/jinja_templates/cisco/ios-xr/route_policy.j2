{# route_policy.j2 — ios-xr #}
! Route Policy
! Intent: {{ intent_id }}
!
{% for entry in entries | default([]) %}
route-policy {{ policy_name }}
{% if entry.match_prefix_set | default("") %}
  if destination in {{ entry.match_prefix_set }} then
{% endif %}
{% if entry.set_local_pref | default("") %}
    set local-preference {{ entry.set_local_pref }}
{% endif %}
{% if entry.set_med | default("") %}
    set med {{ entry.set_med }}
{% endif %}
{% if entry.set_community | default("") %}
    set community {{ entry.set_community }}
{% endif %}
{% if entry.action | default("pass") == "pass" %}
    pass
{% elif entry.action == "drop" %}
    drop
{% endif %}
{% if entry.match_prefix_set | default("") %}
  endif
{% endif %}
end-policy
{% endfor %}
!

{# qos_classify_removal.j2 — ios-xr #}
! Remove QoS
! Intent: {{ intent_id }}
!
{% for iface in apply_interfaces | default([]) %}
interface {{ iface }}
 no service-policy input {{ policy_map }}
{% endfor %}
no policy-map {{ policy_map }}
{% for cm in class_maps | default([]) %}
no class-map {{ cm.name }}
{% endfor %}
!

{# fhrp.j2 — ios-xr #}
! FHRP (HSRP)
! Intent: {{ intent_id }}
!
{% for group in groups | default([]) %}
router hsrp
 interface {{ group.interface }}
  address-family ipv4
   hsrp {{ group.group_id }}
    address {{ group.virtual_ip }}
    priority {{ group.priority | default(100) }}
{% if group.preempt | default(false) %}
    preempt
{% endif %}
{% if group.track | default("") %}
    track object {{ group.track }} {{ group.decrement | default(10) }}
{% endif %}
{% endfor %}
!

{# syslog.j2 — ios-xr #}
! Syslog Configuration
! Intent: {{ intent_id }}
!
{% if source_interface | default("") %}
logging source-interface {{ source_interface }}
{% endif %}
{% for server in servers | default([]) %}
logging {{ server }}
{% endfor %}
{% if facility | default("") %}
logging facility {{ facility }}
{% endif %}
logging trap {{ severity | default("informational") }}
service timestamps log datetime msec
!

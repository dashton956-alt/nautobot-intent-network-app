{# anycast_gateway.j2 — ios-xr #}
! Anycast Gateway (BVI)
! Intent: {{ intent_id }}
!
interface BVI{{ vlan_id }}
 ipv4 address {{ ip_address }} {{ subnet_mask | default("255.255.255.0") }}
{% if description | default("") %}
 description {{ description }}
{% endif %}
{% if vrf | default("") %}
 vrf {{ vrf }}
{% endif %}
!

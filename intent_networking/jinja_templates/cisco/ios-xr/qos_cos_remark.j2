{# qos_cos_remark.j2 — ios-xr #}
! QoS CoS Remark
! Intent: {{ intent_id }}
! Note: IOS-XR uses policy-map for CoS remarking.
!
policy-map {{ policy_map | default("COS-REMARK") }}
{% for entry in cos_map | default([]) %}
 class COS-{{ entry.cos }}
  set dscp {{ entry.dscp }}
{% endfor %}
end-policy-map
!

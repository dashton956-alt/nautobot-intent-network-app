{# mgmt_interface.j2 — ios-xr #}
! Management Interface
! Intent: {{ intent_id }}
!
interface {{ interface | default("MgmtEth0/RP0/CPU0/0") }}
 ipv4 address {{ ip_address }} {{ subnet_mask | default("255.255.255.0") }}
 no shutdown
{% if vrf | default("") %}
 vrf {{ vrf }}
{% endif %}
{% if gateway | default("") %}
!
router static
 address-family ipv4 unicast
  0.0.0.0/0 {{ gateway }}
{% endif %}
!

{# bgp_evpn_af.j2 — ios-xr #}
! BGP EVPN Address Family
! Intent: {{ intent_id }}
!
router bgp {{ local_asn }}
{% for neighbor in neighbors | default([]) %}
 neighbor {{ neighbor.ip }}
  remote-as {{ neighbor.remote_as | default(local_asn) }}
  address-family l2vpn evpn
{% if neighbor.send_community | default(true) %}
   send-community-ebgp
{% endif %}
{% if neighbor.route_reflector_client | default(false) %}
   route-reflector-client
{% endif %}
{% endfor %}
!

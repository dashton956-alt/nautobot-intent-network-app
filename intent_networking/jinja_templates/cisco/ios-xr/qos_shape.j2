{# qos_shape.j2 — ios-xr #}
! QoS Traffic Shaping
! Intent: {{ intent_id }}
!
policy-map {{ policy_map }}
 class class-default
  shape average {{ rate_bps }}
{% if child_policy | default("") %}
  service-policy {{ child_policy }}
{% endif %}
end-policy-map
!
{% for iface in apply_interfaces | default([]) %}
interface {{ iface }}
 service-policy output {{ policy_map }}
{% endfor %}
!

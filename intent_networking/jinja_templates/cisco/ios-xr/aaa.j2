{# aaa.j2 — ios-xr #}
! AAA Configuration
! Intent: {{ intent_id }}
!
aaa authentication login default {{ auth_methods | default("local") }}
{% if enable_auth | default("") %}
aaa authentication enable default {{ enable_auth }}
{% endif %}
{% if authorization | default("") %}
aaa authorization exec default {{ authorization }}
{% endif %}
{% if accounting | default("") %}
aaa accounting exec default start-stop {{ accounting }}
{% endif %}
{% for server in tacacs_servers | default([]) %}
tacacs-server host {{ server.ip | default(server) }}{% if server.key | default("") %} key {{ server.key }}{% endif %}

{% endfor %}
{% for server in radius_servers | default([]) %}
radius-server host {{ server.ip | default(server) }}{% if server.key | default("") %} key {{ server.key }}{% endif %}

{% endfor %}
!

{# nat.j2 — ios-xr #}
! NAT Configuration (CGNAT on IOS-XR)
! Intent: {{ intent_id }}
!
{% if nat_type | default("") == "static" %}
{% for mapping in static_mappings | default([]) %}
interface {{ inside_interface | default("") }}
 ipv4 address {{ mapping.inside }}
{% endfor %}
{% endif %}
! Note: IOS-XR uses Service CGN or external NAT for full NAT functionality.
!

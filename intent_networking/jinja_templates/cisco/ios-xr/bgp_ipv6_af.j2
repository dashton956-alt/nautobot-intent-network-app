{# bgp_ipv6_af.j2 — ios-xr #}
! BGP IPv6 Address Family
! Intent: {{ intent_id }}
!
router bgp {{ local_asn }}
{% for neighbor in neighbors | default([]) %}
 neighbor {{ neighbor.ip }}
  address-family ipv6 unicast
{% if neighbor.route_policy_in | default("") %}
   route-policy {{ neighbor.route_policy_in }} in
{% endif %}
{% if neighbor.route_policy_out | default("") %}
   route-policy {{ neighbor.route_policy_out }} out
{% endif %}
{% endfor %}
!

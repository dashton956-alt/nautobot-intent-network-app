{# storm_control.j2 — ios-xr #}
! Storm Control
! Intent: {{ intent_id }}
!
{% for iface in interfaces | default([]) %}
interface {{ iface }}
 storm-control broadcast level {{ broadcast_level | default(1.0) }}
{% if multicast_level | default("") %}
 storm-control multicast level {{ multicast_level }}
{% endif %}
{% endfor %}
!

{# qos_police.j2 — ios-xr #}
! QoS Policing
! Intent: {{ intent_id }}
!
policy-map {{ policy_map }}
 class class-default
  police rate {{ rate_bps }}
   conform-action {{ conform_action | default("transmit") }}
   exceed-action {{ exceed_action | default("drop") }}
   violate-action {{ violate_action | default("drop") }}
end-policy-map
!
{% for iface in apply_interfaces | default([]) %}
interface {{ iface }}
 service-policy input {{ policy_map }}
{% endfor %}
!

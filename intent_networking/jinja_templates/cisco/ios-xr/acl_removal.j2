{# acl_removal.j2 — ios-xr #}
! Remove ACL
! Intent: {{ intent_id }}
!
{% for iface in apply_interfaces | default([]) %}
interface {{ iface }}
{% if direction | default("in") == "in" or direction | default("") == "both" %}
 no ipv4 access-group {{ acl_name }} ingress
{% endif %}
{% if direction | default("") == "out" or direction | default("") == "both" %}
 no ipv4 access-group {{ acl_name }} egress
{% endif %}
{% endfor %}
no ipv4 access-list {{ acl_name }}
!

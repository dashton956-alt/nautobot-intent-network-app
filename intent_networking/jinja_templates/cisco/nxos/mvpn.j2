{# mvpn.j2 — nxos #}
! MVPN Configuration
! Intent: {{ intent_id }}
!
feature pim
!
router bgp {{ local_asn }}
{% if vrf | default("") %}
  vrf {{ vrf }}
{% endif %}
    address-family ipv4 multicast
{% for neighbor in neighbors | default([]) %}
  neighbor {{ neighbor.ip }}
    address-family ipv4 multicast
      send-community extended
{% endfor %}
{% if mdt_default | default("") %}
vrf context {{ vrf }}
  ip pim rp-address {{ mdt_default }}
{% endif %}

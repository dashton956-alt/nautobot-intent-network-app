{# snmp.j2 — nxos #}
! SNMP Configuration
! Intent: {{ intent_id }}
!
{% if location | default("") %}
snmp-server location {{ location }}
{% endif %}
{% if contact | default("") %}
snmp-server contact {{ contact }}
{% endif %}
{% if version | default("v2c") == "v3" %}
{% for view in views | default([]) %}
snmp-server view {{ view.name }} {{ view.oid }} included
{% endfor %}
{% for group in groups | default([]) %}
snmp-server group {{ group.name }} v3 {{ group.security_level | default("priv") }}{% if group.read_view | default("") %} read {{ group.read_view }}{% endif %}{% if group.write_view | default("") %} write {{ group.write_view }}{% endif %}

{% endfor %}
{% for user in users | default([]) %}
snmp-server user {{ user.name }} {{ user.group }} v3 auth {{ user.auth_protocol | default("sha") }} {{ user.auth_password }} priv {{ user.priv_protocol | default("aes-128") }} {{ user.priv_password }}
{% endfor %}
{% elif community | default("") %}
snmp-server community {{ community }} ro
{% endif %}
{% for target in trap_targets | default([]) %}
snmp-server host {{ target }}{% if version | default("v2c") == "v3" %} version 3 priv{% elif community | default("") %} version 2c {{ community }}{% endif %}

{% endfor %}
{% if trap_targets | default([]) %}
snmp-server enable traps
{% endif %}

{# bgp_ipv6_af.j2 — nxos #}
! BGP IPv6 Address Family
! Intent: {{ intent_id }}
!
router bgp {{ local_asn }}
  address-family ipv6 unicast
{% for net in networks | default([]) %}
    network {{ net }}
{% endfor %}
{% for neighbor in neighbors | default([]) %}
  neighbor {{ neighbor.ip }}
    address-family ipv6 unicast
{% if neighbor.route_map_in | default("") %}
      route-map {{ neighbor.route_map_in }} in
{% endif %}
{% if neighbor.route_map_out | default("") %}
      route-map {{ neighbor.route_map_out }} out
{% endif %}
{% endfor %}

{# ospfv3.j2 — nxos #}
! OSPFv3 Configuration
! Intent: {{ intent_id }}
!
feature ospfv3
!
router ospfv3 {{ process_id }}
  router-id {{ router_id }}
!
{% for iface in interfaces | default([]) %}
interface {{ iface.name }}
  ospfv3 {{ process_id }} area {{ iface.area | default(area) }} ipv6
{% endfor %}
!
{% for route in redistribute | default([]) %}
router ospfv3 {{ process_id }}
  address-family ipv6 unicast
    redistribute {{ route }} route-map PERMIT-ALL
{% endfor %}

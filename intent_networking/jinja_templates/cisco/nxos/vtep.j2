{# vtep.j2 — nxos #}
! Primitive: vtep
! Intent: {{ intent_id }}
! Platform: Cisco NX-OS
!
! Variables:
!   nve_interface      — NVE interface name (e.g. nve1)
!   source_interface   — Source loopback for VTEP (e.g. Loopback0)
!   l2_vni             — Layer 2 VNI value (optional)
!   l3_vni             — Layer 3 VNI value (optional)
!   vni_map            — dict mapping VNI → VLAN (optional)
!   replication_mode   — ingress-replication | multicast
!

feature vxlan
feature nv overlay

interface {{ nve_interface | default('nve1') }}
  no shutdown
  host-reachability protocol bgp
  source-interface {{ source_interface | default('Loopback0') }}
{% for v in l2_vni | default([]) %}
  member vni {{ v.vni }}
{% if replication_mode | default('ingress-replication') == 'ingress-replication' %}
    ingress-replication protocol bgp
{% else %}
    mcast-group {{ v.mcast_group | default('239.0.0.1') }}
{% endif %}
{% endfor %}
{% for v in l3_vni | default([]) %}
  member vni {{ v.vni }} associate-vrf
{% endfor %}
{% for m in vni_map | default([]) %}
  member vni {{ m.vni }}
{% if replication_mode | default('ingress-replication') == 'ingress-replication' %}
    ingress-replication protocol bgp
{% endif %}
{% endfor %}

{# aaa.j2 — aos-cx #}
! AAA Configuration
! Intent: {{ intent_id }}
!
{% for method in authentication_methods | default(["tacacs", "local"]) %}
{% endfor %}
aaa authentication login default group {{ authentication_methods | default(["tacacs", "local"]) | join(" ") }}
{% if accounting | default(false) %}
aaa accounting all-mgmt default start-stop group {{ accounting_group | default("tacacs") }}
{% endif %}
{% if authorization | default(false) %}
aaa authorization commands default group {{ authorization_group | default("tacacs") }} local
{% endif %}

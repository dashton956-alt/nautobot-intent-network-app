{# qos_dscp_mark.j2 — aos-cx #}
! QoS DSCP Marking
! Intent: {{ intent_id }}
!
qos dscp-map {{ dscp_map_name | default("DSCP-MARK") }}
{% for entry in entries | default([]) %}
    {{ entry.dscp | default(0) }} local-priority {{ entry.local_priority | default(0) }} color {{ entry.color | default("green") }}
{% endfor %}
{% for iface in interfaces | default([]) %}
interface {{ iface }}
    apply qos dscp-map {{ dscp_map_name | default("DSCP-MARK") }}
{% endfor %}

{# qos_queue.j2 — aos-cx #}
! QoS Queuing
! Intent: {{ intent_id }}
!
qos queue-profile {{ profile_name | default("QOS-QUEUES") }}
{% for queue in queues | default([]) %}
    queue {{ queue.id }} weight {{ queue.weight | default(1) }}
{% if queue.priority | default(false) %}
    queue {{ queue.id }} strict
{% endif %}
{% endfor %}
{% for iface in interfaces | default([]) %}
interface {{ iface }}
    apply qos queue-profile {{ profile_name | default("QOS-QUEUES") }}
{% endfor %}

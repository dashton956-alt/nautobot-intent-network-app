{# dhcp_relay.j2 — aos-cx #}
! DHCP Relay
! Intent: {{ intent_id }}
!
{% for server in servers | default([]) %}
dhcp-relay server {{ server }}
{% endfor %}
{% for iface in interfaces | default([]) %}
interface {{ iface }}
    dhcp-relay
{% endfor %}
{% if vrf | default("") %}
dhcp-relay vrf {{ vrf }}
{% endif %}

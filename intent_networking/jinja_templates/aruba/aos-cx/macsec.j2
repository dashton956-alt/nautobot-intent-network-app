{# macsec.j2 — aos-cx #}
! MACsec Configuration
! Intent: {{ intent_id }}
!
macsec policy {{ policy_name | default("MACSEC-POL") }}
    cipher-suite {{ cipher_suite | default("gcm-aes-256") }}
{% if security_mode | default("") %}
    security-mode {{ security_mode }}
{% endif %}
!
{% for iface in interfaces | default([]) %}
interface {{ iface }}
    macsec policy {{ policy_name | default("MACSEC-POL") }}
{% endfor %}

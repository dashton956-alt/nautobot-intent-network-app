{# lldp_cdp.j2 — aos-cx #}
! LLDP Configuration
! Intent: {{ intent_id }}
!
{% if lldp_enabled | default(true) %}
lldp enable
{% else %}
no lldp enable
{% endif %}
{% for iface in interfaces | default([]) %}
interface {{ iface.name }}
{% if iface.lldp_transmit | default(true) %}
    lldp transmit
{% else %}
    no lldp transmit
{% endif %}
{% if iface.lldp_receive | default(true) %}
    lldp receive
{% else %}
    no lldp receive
{% endif %}
{% endfor %}

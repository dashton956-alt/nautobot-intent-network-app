{# netflow.j2 — aos-cx #}
! sFlow (AOS-CX uses sFlow instead of NetFlow)
! Intent: {{ intent_id }}
!
{% for collector in collectors | default([]) %}
sflow {{ collector.ip }} port {{ collector.port | default(6343) }}
{% endfor %}
{% if sample_rate | default("") %}
sflow sampling {{ sample_rate }}
{% endif %}
{% if polling_interval | default("") %}
sflow polling {{ polling_interval }}
{% endif %}
{% for iface in interfaces | default([]) %}
interface {{ iface }}
    sflow enable
{% endfor %}

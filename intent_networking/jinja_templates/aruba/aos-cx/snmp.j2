{# snmp.j2 — aos-cx #}
! SNMP Configuration
! Intent: {{ intent_id }}
!
{% if location | default("") %}
snmp-server system-location "{{ location }}"
{% endif %}
{% if contact | default("") %}
snmp-server system-contact "{{ contact }}"
{% endif %}
{% for community_item in communities | default([]) %}
snmp-server community {{ community_item.name }} {{ community_item.permission | default("public") }}
{% endfor %}
{% for trap_host in trap_targets | default([]) %}
snmp-server host {{ trap_host.ip }}{% if trap_host.version | default("") %} version {{ trap_host.version }}{% endif %} community {{ trap_host.community | default("public") }}
{% if trap_host.traps | default([]) %}
{% for trap in trap_host.traps %}
snmp-server host {{ trap_host.ip }} trap {{ trap }}
{% endfor %}
{% endif %}
{% endfor %}

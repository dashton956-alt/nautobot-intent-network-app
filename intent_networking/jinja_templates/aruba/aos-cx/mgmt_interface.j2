{# mgmt_interface.j2 — aos-cx #}
! Management Interface
! Intent: {{ intent_id }}
!
interface mgmt
    ip {{ ip_address }}/{{ prefix_len | default(24) }}
{% if description | default("") %}
    description {{ description }}
{% endif %}
{% if gateway | default("") %}
    default-gateway {{ gateway }}
{% endif %}
    no shutdown

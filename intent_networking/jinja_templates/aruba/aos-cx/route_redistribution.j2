{# route_redistribution.j2 — aos-cx #}
! Route Redistribution
! Intent: {{ intent_id }}
!
{% if target_protocol | default("") == "ospf" %}
router ospf {{ process_id | default(1) }}
{% for source in sources | default([]) %}
    redistribute {{ source.protocol }}{% if source.route_map | default("") %} route-map {{ source.route_map }}{% endif %}

{% endfor %}
{% elif target_protocol | default("") == "bgp" %}
router bgp {{ local_asn | default("") }}
{% for source in sources | default([]) %}
    redistribute {{ source.protocol }}{% if source.route_map | default("") %} route-map {{ source.route_map }}{% endif %}

{% endfor %}
{% endif %}

{# gre_tunnel.j2 — aos-cx #}
! GRE Tunnel
! Intent: {{ intent_id }}
!
interface tunnel {{ tunnel_id | default(1) }}
    ip address {{ tunnel_ip }}/{{ prefix_len | default(30) }}
    tunnel source {{ tunnel_source }}
    tunnel destination {{ tunnel_destination }}
    tunnel mode gre
{% if description | default("") %}
    description {{ description }}
{% endif %}
{% if mtu | default("") %}
    mtu {{ mtu }}
{% endif %}
    no shutdown

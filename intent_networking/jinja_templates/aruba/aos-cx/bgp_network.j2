{# bgp_network.j2 — aos-cx #}
! BGP Network Advertisement
! Intent: {{ intent_id }}
!
router bgp {{ local_asn }}
{% if vrf | default("") %}
    vrf {{ vrf }}
{% endif %}
    address-family ipv4 unicast
{% for net in networks | default([]) %}
        network {{ net }}
{% endfor %}
    exit-address-family

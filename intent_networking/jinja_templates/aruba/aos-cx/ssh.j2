{# ssh.j2 — aos-cx #}
! SSH Configuration
! Intent: {{ intent_id }}
!
ssh server vrf {{ vrf | default("default") }}
{% if max_sessions | default("") %}
ssh maximum-sessions {{ max_sessions }}
{% endif %}
{% if timeout | default("") %}
ssh idle-timeout {{ timeout }}
{% endif %}
{% for key_type in host_key_algorithms | default([]) %}
ssh host-key {{ key_type }}
{% endfor %}

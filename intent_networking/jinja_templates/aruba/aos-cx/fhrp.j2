{# fhrp.j2 — aos-cx #}
! FHRP (VRRP)
! Intent: {{ intent_id }}
!
{% for group in groups | default([]) %}
interface {{ group.interface }}
    vrrp {{ group.group_id }} address-family ipv4
    vrrp {{ group.group_id }} ip {{ group.virtual_ip }}
    vrrp {{ group.group_id }} priority {{ group.priority | default(100) }}
{% if group.preempt | default(true) %}
    vrrp {{ group.group_id }} preempt
{% endif %}
{% if group.track | default("") %}
    vrrp {{ group.group_id }} track interface {{ group.track }} {{ group.decrement | default(10) }}
{% endif %}
{% endfor %}

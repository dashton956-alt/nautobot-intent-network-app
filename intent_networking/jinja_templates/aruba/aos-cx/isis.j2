{# isis.j2 — aos-cx #}
! IS-IS Configuration
! Intent: {{ intent_id }}
!
router isis {{ instance | default(1) }}
{% if net | default("") %}
    net {{ net }}
{% endif %}
    is-type {{ level | default("level-2-only") }}
{% if metric_style | default("wide") == "wide" %}
    metric-style wide
{% endif %}
!
{% for iface in interfaces | default([]) %}
interface {{ iface.name }}
    isis enable {{ instance | default(1) }}
{% if iface.passive | default(false) %}
    isis passive
{% endif %}
{% if iface.network_type | default("") == "point-to-point" %}
    isis network point-to-point
{% endif %}
{% if iface.metric | default("") %}
    isis metric {{ iface.metric }}
{% endif %}
{% endfor %}

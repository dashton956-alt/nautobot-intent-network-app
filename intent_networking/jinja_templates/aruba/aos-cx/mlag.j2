{# mlag.j2 — aos-cx #}
! VSX (AOS-CX MLAG)
! Intent: {{ intent_id }}
!
vsx
    inter-switch-link lag {{ isl_lag | default(256) }}
    role {{ role | default("primary") }}
    keepalive peer {{ peer_ip }} source {{ source_ip | default("") }}
    system-mac {{ system_mac | default("") }}
{% for bundle in bundles | default([]) %}
interface lag {{ bundle.id }}
    vsx-sync active-gateways vlans policies
    lacp mode active
{% for member in bundle.members | default([]) %}
interface {{ member }}
    lag {{ bundle.id }}
{% endfor %}
{% endfor %}

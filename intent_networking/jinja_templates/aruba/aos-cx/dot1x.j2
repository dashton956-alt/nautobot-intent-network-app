{# dot1x.j2 — aos-cx #}
! 802.1X Authentication
! Intent: {{ intent_id }}
!
aaa authentication port-access dot1x authenticator
{% for iface in interfaces | default([]) %}
interface {{ iface.name }}
    aaa authentication port-access dot1x authenticator
{% if iface.mac_auth | default(false) %}
    aaa authentication port-access mac-auth
{% endif %}
{% if iface.guest_vlan | default("") %}
    aaa authentication port-access dot1x authenticator auth-vid {{ iface.guest_vlan }}
{% endif %}
    aaa authentication port-access dot1x authenticator enable
{% endfor %}

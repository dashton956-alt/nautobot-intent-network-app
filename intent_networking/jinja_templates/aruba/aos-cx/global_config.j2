{# global_config.j2 — aos-cx #}
! ═══════════════════════════════════════════════════════════
! Global Configuration Bundle
! Intent: {{ intent_id }}
! ═══════════════════════════════════════════════════════════
!
{% if hostname %}
hostname {{ hostname }}
{% endif %}
!
{% if domain_name %}
ip domain-name {{ domain_name }}
{% endif %}
{% for server in dns_servers | default([]) %}
ip dns server-address {{ server }}
{% endfor %}
!
! ── NTP ───────────────────────────────────────────────────
{% if ntp_source_interface %}
ntp source-interface {{ ntp_source_interface }}
{% endif %}
{% for server in ntp_servers | default([]) %}
{% if server == ntp_prefer %}
ntp server {{ server }} prefer
{% else %}
ntp server {{ server }}
{% endif %}
{% endfor %}
!
! ── Logging / Syslog ─────────────────────────────────────
{% for server in syslog_servers | default([]) %}
logging {{ server }} severity {{ syslog_severity | default("info") }} facility {{ syslog_facility | default("local7") }}
{% endfor %}
!
! ── SNMP ──────────────────────────────────────────────────
{% if snmp_location %}
snmp-server system-location {{ snmp_location }}
{% endif %}
{% if snmp_contact %}
snmp-server system-contact {{ snmp_contact }}
{% endif %}
{% if snmp_version == "v3" %}
{% for view in snmp_views | default([]) %}
snmp-server view {{ view.name }} {{ view.oid }} include
{% endfor %}
{% for group in snmp_groups | default([]) %}
snmp-server group {{ group.name }} v3 {{ group.security_level | default("priv") }}{% if group.read_view %} read {{ group.read_view }}{% endif %}

{% endfor %}
{% for user in snmp_users | default([]) %}
snmp-server user {{ user.name }} group {{ user.group }} v3 auth {{ user.auth_protocol | default("sha") }} auth-pass plaintext {{ user.auth_password }} priv {{ user.priv_protocol | default("aes") }} priv-pass plaintext {{ user.priv_password }}
{% endfor %}
{% elif snmp_community %}
snmp-server community {{ snmp_community }}
{% endif %}
{% for target in snmp_trap_targets | default([]) %}
snmp-server host {{ target }}{% if snmp_community %} community {{ snmp_community }}{% endif %} trap version v2c
{% endfor %}
!
! ── Banner / MOTD ─────────────────────────────────────────
{% if login_banner %}
banner login "{{ login_banner }}"
{% endif %}
{% if motd_banner %}
banner motd "{{ motd_banner }}"
{% endif %}
!
! ── SSH ───────────────────────────────────────────────────
{% if enable_ssh %}
ssh server vrf default
ssh idle-timeout {{ ssh_timeout | default(60) }}
{% endif %}
!
! ── NETCONF / REST API ────────────────────────────────────
{% if enable_restconf %}
https-server rest access-mode read-write
https-server vrf default
{% endif %}
!
! ── LLDP ──────────────────────────────────────────────────
{% if enable_lldp is defined %}
{% if enable_lldp %}
lldp enable
{% else %}
no lldp enable
{% endif %}
{% endif %}
!
! ── DHCP Server ───────────────────────────────────────────
{% for pool in dhcp_pools | default([]) %}
dhcp-server pool {{ pool.name }}
{% if pool.network %}
 network {{ pool.network }}
{% endif %}
{% if pool.default_router %}
 default-router {{ pool.default_router }}
{% endif %}
{% if pool.dns_server %}
 dns-server {{ pool.dns_server }}
{% endif %}
 lease 1 0 0
 exit
!
{% endfor %}

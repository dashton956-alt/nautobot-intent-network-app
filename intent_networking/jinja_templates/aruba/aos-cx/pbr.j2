{# pbr.j2 — aos-cx #}
! Policy-Based Routing
! Intent: {{ intent_id }}
!
{% for entry in entries | default([]) %}
route-map {{ route_map_name | default("PBR-MAP") }} {{ entry.action | default("permit") }} {{ entry.sequence | default(loop.index * 10) }}
{% if entry.match_acl | default("") %}
    match ip address {{ entry.match_acl }}
{% endif %}
{% if entry.set_next_hop | default("") %}
    set ip next-hop {{ entry.set_next_hop }}
{% endif %}
{% endfor %}
!
{% for iface in apply_interfaces | default([]) %}
interface {{ iface }}
    ip policy route-map {{ route_map_name | default("PBR-MAP") }}
{% endfor %}

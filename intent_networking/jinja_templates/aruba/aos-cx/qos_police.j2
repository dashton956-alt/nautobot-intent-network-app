{# qos_police.j2 — aos-cx #}
! QoS Policing
! Intent: {{ intent_id }}
!
{% for policer in policers | default([]) %}
qos rate {{ policer.name }} {{ policer.rate | default("1000000") }} kbps burst {{ policer.burst | default("15000") }}
{% endfor %}
{% for iface in policy_interfaces | default([]) %}
interface {{ iface.name }}
    apply qos rate {{ iface.policer }} in
{% endfor %}

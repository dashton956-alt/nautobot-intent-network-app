{# pvlan.j2 — aos-cx #}
! Private VLAN
! Intent: {{ intent_id }}
!
{% if primary_vlan | default("") %}
vlan {{ primary_vlan }}
    private-vlan primary
{% for secondary in secondary_vlans | default([]) %}
    private-vlan association {{ secondary }}
{% endfor %}
{% endif %}
{% for secondary in secondary_vlans | default([]) %}
vlan {{ secondary }}
    private-vlan {{ pvlan_type | default("isolated") }}
{% endfor %}

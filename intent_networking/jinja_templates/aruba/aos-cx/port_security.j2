{# port_security.j2 — aos-cx #}
! Port Security
! Intent: {{ intent_id }}
!
{% for iface in interfaces | default([]) %}
interface {{ iface }}
    port-access port-security
    port-access port-security max-mac-addr {{ max_mac | default(5) }}
    port-access port-security violation {{ violation_action | default("shutdown") }}
{% endfor %}

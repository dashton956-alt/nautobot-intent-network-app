{# qos_classify.j2 — aos-cx #}
! QoS Classification
! Intent: {{ intent_id }}
!
{% for cls in classes | default([]) %}
class ip {{ cls.name }}
    match dscp {{ cls.dscp | default("") }}
{% endfor %}
{% for iface in interfaces | default([]) %}
interface {{ iface }}
    apply qos {{ policy_name | default("QOS-CLASS") }} in
{% endfor %}

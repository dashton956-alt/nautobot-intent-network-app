{# ipsec_ikev2.j2 — aos-cx #}
! IPsec IKEv2
! Intent: {{ intent_id }}
!
crypto ikev2 proposal {{ proposal_name | default("IKEv2-PROP") }}
    encryption {{ encryption | default("aes-cbc-256") }}
    integrity {{ integrity | default("sha256") }}
    group {{ dh_group | default(14) }}
!
crypto ikev2 policy {{ policy_name | default("IKEv2-POL") }}
    proposal {{ proposal_name | default("IKEv2-PROP") }}
!
crypto ikev2 keyring {{ keyring_name | default("IKEv2-KEYRING") }}
    peer {{ peer_name | default("PEER-1") }}
        address {{ peer_ip }}
        pre-shared-key "{{ psk }}"
!
crypto ikev2 profile {{ profile_name | default("IKEv2-PROF") }}
    match identity remote address {{ peer_ip }}
    authentication local pre-share
    authentication remote pre-share
    keyring {{ keyring_name | default("IKEv2-KEYRING") }}

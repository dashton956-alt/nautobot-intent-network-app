{# wan_uplink.j2 — aos-cx #}
! WAN Uplink
! Intent: {{ intent_id }}
!
interface {{ interface }}
    ip address {{ ip_address }}/{{ prefix_len | default(30) }}
{% if description | default("") %}
    description {{ description }}
{% endif %}
{% if speed | default("") %}
    speed {{ speed }}
{% endif %}
{% if mtu | default("") %}
    mtu {{ mtu }}
{% endif %}
{% if vrf | default("") %}
    vrf attach {{ vrf }}
{% endif %}
    no shutdown

{# anycast_gateway.j2 — aos-cx #}
! Anycast Gateway
! Intent: {{ intent_id }}
!
interface vlan {{ vlan_id }}
    ip address {{ ip_address }}/{{ prefix_len | default(24) }}
{% if virtual_ip | default("") %}
    active-gateway ip mac {{ virtual_mac | default("00:00:00:00:01:00") }}
    active-gateway ip {{ virtual_ip }}
{% endif %}
{% if description | default("") %}
    description {{ description }}
{% endif %}
{% if vrf | default("") %}
    vrf attach {{ vrf }}
{% endif %}
    no shutdown

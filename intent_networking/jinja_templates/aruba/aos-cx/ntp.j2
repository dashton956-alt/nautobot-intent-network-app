{# ntp.j2 — aos-cx #}
! NTP Configuration
! Intent: {{ intent_id }}
!
{% for server in servers | default([]) %}
ntp server {{ server.ip }}{% if server.prefer | default(false) %} prefer{% endif %}

{% endfor %}
{% if source_interface | default("") %}
ntp source-interface {{ source_interface }}
{% endif %}
{% if vrf | default("") %}
ntp vrf {{ vrf }}
{% endif %}

{# ospfv3.j2 — aos-cx #}
! OSPFv3 Configuration
! Intent: {{ intent_id }}
!
router ospfv3 {{ process_id | default(1) }}
{% if router_id | default("") %}
    router-id {{ router_id }}
{% endif %}
!
{% for iface in interfaces | default([]) %}
interface {{ iface.name }}
    ipv6 ospfv3 {{ process_id | default(1) }} area {{ iface.area | default("0.0.0.0") }}
{% endfor %}

{# qos_cos_remark.j2 — aos-cx #}
! QoS CoS Remark
! Intent: {{ intent_id }}
!
qos cos-map {{ cos_map_name | default("COS-REMARK") }}
{% for entry in entries | default([]) %}
    {{ entry.cos | default(0) }} local-priority {{ entry.local_priority | default(0) }} color {{ entry.color | default("green") }}
{% endfor %}
{% for iface in interfaces | default([]) %}
interface {{ iface }}
    apply qos cos-map {{ cos_map_name | default("COS-REMARK") }}
{% endfor %}

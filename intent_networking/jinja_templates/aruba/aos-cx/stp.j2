{# stp.j2 — aos-cx #}
! STP Configuration
! Intent: {{ intent_id }}
!
{% if mode | default("rstp") == "rstp" %}
spanning-tree mode rpvst
{% elif mode == "mstp" %}
spanning-tree mode mstp
spanning-tree instance {{ mst_instance | default(1) }} vlan {{ mst_vlans | default("") }}
{% endif %}
{% if bpdu_guard_default | default(false) %}
spanning-tree bpdu-guard
{% endif %}
{% if root_guard_default | default(false) %}
spanning-tree root-guard
{% endif %}

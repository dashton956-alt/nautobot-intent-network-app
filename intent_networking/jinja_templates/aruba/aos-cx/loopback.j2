{# loopback.j2 — aos-cx #}
! Loopback Interface
! Intent: {{ intent_id }}
!
interface loopback {{ loopback_id | default(0) }}
    ip address {{ ip_address }}/{{ prefix_len | default(32) }}
{% if description | default("") %}
    description {{ description }}
{% endif %}
{% if vrf | default("") %}
    vrf attach {{ vrf }}
{% endif %}
    no shutdown

{# anycast_gateway.j2 — junos #}
! Anycast Gateway (IRB)
! Intent: {{ intent_id }}
!
set interfaces irb unit {{ vlan_id }} family inet address {{ ip_address }}/{{ prefix_len | default(24) }} virtual-gateway-address {{ virtual_ip | default("") }}
{% if description | default("") %}
set interfaces irb unit {{ vlan_id }} description "{{ description }}"
{% endif %}
{% if vrf | default("") %}
set routing-instances {{ vrf }} interface irb.{{ vlan_id }}
{% endif %}
{% if virtual_mac | default("") %}
set interfaces irb unit {{ vlan_id }} virtual-gateway-v4-mac {{ virtual_mac }}
{% endif %}

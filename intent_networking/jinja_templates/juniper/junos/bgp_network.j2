{# bgp_network.j2 — junos #}
! BGP Network Advertisement
! Intent: {{ intent_id }}
!
{% if vrf | default("") %}
{% for net in networks | default([]) %}
set routing-instances {{ vrf }} routing-options static route {{ net }} discard
set routing-instances {{ vrf }} protocols bgp group {{ bgp_group | default("EBGP") }} export ADVERTISE-{{ net | replace("/", "-") | replace(".", "-") }}
{% endfor %}
{% else %}
{% for net in networks | default([]) %}
set routing-options static route {{ net }} discard
{% endfor %}
set policy-options policy-statement BGP-EXPORT term NETWORKS from route-filter {{ networks | join(' exact ') }} exact
set policy-options policy-statement BGP-EXPORT term NETWORKS then accept
{% endif %}

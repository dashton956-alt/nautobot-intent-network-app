{# vtep.j2 — junos #}
! VTEP / VXLAN Tunnel
! Intent: {{ intent_id }}
!
set interfaces lo0 unit 0 family inet address {{ source_ip | default("") }}/32
set switch-options vtep-source-interface lo0.0
set protocols evpn encapsulation vxlan
set protocols evpn multicast-mode ingress-replication
{% for vni in vnis | default([]) %}
set vlans VNI-{{ vni.id }} vxlan vni {{ vni.id }}
{% endfor %}

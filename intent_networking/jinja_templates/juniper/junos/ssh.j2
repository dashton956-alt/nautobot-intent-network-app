{# ssh.j2 — junos #}
! SSH Configuration
! Intent: {{ intent_id }}
!
set system services ssh
{% if ssh_version | default("") %}
set system services ssh protocol-version {{ ssh_version }}
{% endif %}
{% if max_sessions | default("") %}
set system services ssh max-sessions-per-connection {{ max_sessions }}
{% endif %}
{% if timeout | default("") %}
set system login retry-options backoff-threshold 1
set system login retry-options lockout-period {{ timeout }}
{% endif %}
{% if rate_limit | default("") %}
set system services ssh rate-limit {{ rate_limit }}
{% endif %}
{% for key_type in ciphers | default([]) %}
{% endfor %}
{% for acl_entry in access_list | default([]) %}
set system services ssh root-login deny
{% endfor %}

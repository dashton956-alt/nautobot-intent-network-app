{# qinq.j2 — junos #}
! QinQ (Stacked VLANs)
! Intent: {{ intent_id }}
!
{% for iface in interfaces | default([]) %}
set interfaces {{ iface.name }} flexible-vlan-tagging
set interfaces {{ iface.name }} encapsulation flexible-ethernet-services
{% if iface.outer_vlan | default("") %}
set interfaces {{ iface.name }} unit {{ iface.unit | default(0) }} vlan-id {{ iface.outer_vlan }}
set interfaces {{ iface.name }} unit {{ iface.unit | default(0) }} input-vlan-map push
set interfaces {{ iface.name }} unit {{ iface.unit | default(0) }} output-vlan-map pop
{% endif %}
{% endfor %}

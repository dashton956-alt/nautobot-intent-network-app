{# gre_tunnel.j2 — junos #}
! GRE Tunnel
! Intent: {{ intent_id }}
!
set interfaces {{ tunnel_interface | default("gr-0/0/0") }} unit {{ tunnel_id | default(0) }} tunnel source {{ tunnel_source }}
set interfaces {{ tunnel_interface | default("gr-0/0/0") }} unit {{ tunnel_id | default(0) }} tunnel destination {{ tunnel_destination }}
set interfaces {{ tunnel_interface | default("gr-0/0/0") }} unit {{ tunnel_id | default(0) }} family inet address {{ tunnel_ip }}/{{ prefix_len | default(30) }}
{% if description | default("") %}
set interfaces {{ tunnel_interface | default("gr-0/0/0") }} unit {{ tunnel_id | default(0) }} description "{{ description }}"
{% endif %}
{% if mtu | default("") %}
set interfaces {{ tunnel_interface | default("gr-0/0/0") }} unit {{ tunnel_id | default(0) }} family inet mtu {{ mtu }}
{% endif %}

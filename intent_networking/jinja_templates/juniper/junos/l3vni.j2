{# l3vni.j2 — junos #}
! L3 VNI (VXLAN)
! Intent: {{ intent_id }}
!
set routing-instances {{ vrf_name }} instance-type vrf
set routing-instances {{ vrf_name }} route-distinguisher {{ rd | default("auto") }}
set routing-instances {{ vrf_name }} vrf-target target:{{ rt_import | default("auto") }}
{% for iface in interfaces | default([]) %}
set routing-instances {{ vrf_name }} interface {{ iface }}
{% endfor %}

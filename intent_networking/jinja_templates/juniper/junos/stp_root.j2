{# stp_root.j2 — junos #}
! STP Root Bridge
! Intent: {{ intent_id }}
!
{% for vlan in primary_vlans | default([]) %}
set protocols vstp vlan {{ vlan }} bridge-priority {{ priority | default(4096) }}
{% endfor %}
{% for vlan in secondary_vlans | default([]) %}
set protocols vstp vlan {{ vlan }} bridge-priority {{ secondary_priority | default(8192) }}
{% endfor %}

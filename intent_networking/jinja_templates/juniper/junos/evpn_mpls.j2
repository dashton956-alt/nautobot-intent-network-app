{# evpn_mpls.j2 — junos #}
! EVPN over MPLS
! Intent: {{ intent_id }}
!
set routing-instances {{ instance_name | default("EVPN-1") }} instance-type evpn
set routing-instances {{ instance_name | default("EVPN-1") }} route-distinguisher {{ rd | default("auto") }}
set routing-instances {{ instance_name | default("EVPN-1") }} vrf-target target:{{ rt_import | default("auto") }}
set routing-instances {{ instance_name | default("EVPN-1") }} protocols evpn
{% for iface in interfaces | default([]) %}
set routing-instances {{ instance_name | default("EVPN-1") }} interface {{ iface }}
{% endfor %}

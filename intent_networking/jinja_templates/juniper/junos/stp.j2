{# stp.j2 — junos #}
! STP Configuration
! Intent: {{ intent_id }}
!
{% if mode | default("rstp") == "rstp" %}
set protocols rstp
{% elif mode == "mstp" %}
set protocols mstp
{% elif mode == "vstp" %}
set protocols vstp
{% endif %}
{% if bpdu_guard_default | default(false) %}
set protocols rstp bpdu-block-on-edge
{% endif %}
{% for vlan in vlans | default([]) %}
set protocols rstp bridge-priority {{ vlan.priority | default(32768) }}
{% endfor %}

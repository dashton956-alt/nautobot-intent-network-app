{# l2vni.j2 — junos #}
! L2 VNI (VXLAN)
! Intent: {{ intent_id }}
!
set vlans {{ vlan_name | default("VLAN" ~ vlan_id) }} vlan-id {{ vlan_id }}
set vlans {{ vlan_name | default("VLAN" ~ vlan_id) }} vxlan vni {{ vni_id }}
{% if ingress_replication | default(true) %}
set vlans {{ vlan_name | default("VLAN" ~ vlan_id) }} vxlan ingress-node-replication
{% endif %}

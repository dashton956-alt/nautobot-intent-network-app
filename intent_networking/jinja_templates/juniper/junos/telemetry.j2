{# telemetry.j2 — junos #}
! Streaming Telemetry (gRPC)
! Intent: {{ intent_id }}
!
{% if destination_ip | default("") %}
set services analytics streaming-server {{ server_name | default("TELEMETRY") }} remote-address {{ destination_ip }}
set services analytics streaming-server {{ server_name | default("TELEMETRY") }} remote-port {{ destination_port | default(50051) }}
{% endif %}
{% for sub in subscriptions | default([]) %}
set services analytics sensor {{ sub.name | default("sensor-" ~ loop.index) }} server-name {{ server_name | default("TELEMETRY") }}
set services analytics sensor {{ sub.name | default("sensor-" ~ loop.index) }} resource {{ sub.path }}
set services analytics sensor {{ sub.name | default("sensor-" ~ loop.index) }} reporting-rate {{ sub.interval | default(30) }}
{% endfor %}

{# igmp_snooping.j2 — junos #}
! IGMP Snooping
! Intent: {{ intent_id }}
!
{% for vlan_item in vlans | default([]) %}
set protocols igmp-snooping vlan VLAN{{ vlan_item }}
{% endfor %}
{% if querier | default(false) %}
set protocols igmp-snooping vlan {{ querier_vlan_name | default("default") }} l2-querier source-address {{ querier_source | default("") }}
{% endif %}

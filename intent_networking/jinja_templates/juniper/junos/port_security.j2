{# port_security.j2 — junos #}
! Port Security
! Intent: {{ intent_id }}
!
{% for iface in interfaces | default([]) %}
set interfaces {{ iface }} unit 0 family ethernet-switching mac-limit {{ max_mac | default(5) }}
set interfaces {{ iface }} unit 0 family ethernet-switching mac-limit action {{ violation_action | default("drop") }}
{% endfor %}

{# qos_trust.j2 — junos #}
! QoS Trust
! Intent: {{ intent_id }}
!
{% for iface in interfaces | default([]) %}
{% if trust_mode | default("dscp") == "dscp" %}
set class-of-service interfaces {{ iface }} unit 0 classifiers dscp default
{% elif trust_mode == "cos" %}
set class-of-service interfaces {{ iface }} unit 0 classifiers ieee-802.1 default
{% endif %}
{% endfor %}

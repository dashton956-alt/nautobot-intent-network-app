{# copp.j2 — junos #}
! Control Plane Policing
! Intent: {{ intent_id }}
!
{% for entry in entries | default([]) %}
set firewall family inet filter COPP term {{ entry.name }} from protocol {{ entry.protocol | default("icmp") }}
{% if entry.source | default("") %}
set firewall family inet filter COPP term {{ entry.name }} from source-address {{ entry.source }}
{% endif %}
set firewall family inet filter COPP term {{ entry.name }} then policer {{ entry.policer | default("CoPP-RATE-1M") }}
set firewall family inet filter COPP term {{ entry.name }} then accept
{% endfor %}
set firewall policer CoPP-RATE-1M if-exceeding bandwidth-limit {{ bandwidth | default("1m") }} burst-size-limit {{ burst | default("15k") }}
set firewall policer CoPP-RATE-1M then discard
set interfaces lo0 unit 0 family inet filter input COPP

{# isis.j2 — junos #}
! IS-IS Configuration
! Intent: {{ intent_id }}
!
set protocols isis level {{ level | default(2) }} wide-metrics-only
{% if net | default("") %}
set routing-options router-id {{ router_id | default("") }}
{% endif %}
{% for iface in interfaces | default([]) %}
set protocols isis interface {{ iface.name }}
{% if iface.metric | default("") %}
set protocols isis interface {{ iface.name }} level {{ level | default(2) }} metric {{ iface.metric }}
{% endif %}
{% if iface.passive | default(false) %}
set protocols isis interface {{ iface.name }} passive
{% endif %}
{% if iface.network_type | default("point-to-point") == "point-to-point" %}
set protocols isis interface {{ iface.name }} point-to-point
{% endif %}
{% endfor %}

{# macsec.j2 — junos #}
! MACsec Configuration
! Intent: {{ intent_id }}
!
set security macsec connectivity-association {{ ca_name | default("MACSEC-CA") }} security-mode static-cak
set security macsec connectivity-association {{ ca_name | default("MACSEC-CA") }} pre-shared-key ckn {{ ckn | default("") }}
set security macsec connectivity-association {{ ca_name | default("MACSEC-CA") }} pre-shared-key cak {{ cak | default("") }}
set security macsec connectivity-association {{ ca_name | default("MACSEC-CA") }} cipher-suite {{ cipher_suite | default("gcm-aes-256") }}
{% for iface in interfaces | default([]) %}
set security macsec interfaces {{ iface }} connectivity-association {{ ca_name | default("MACSEC-CA") }}
{% endfor %}

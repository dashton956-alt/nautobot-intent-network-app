{# l2vpn_vpls.j2 — junos #}
! L2VPN VPLS
! Intent: {{ intent_id }}
!
set routing-instances {{ instance_name | default("VPLS-1") }} instance-type vpls
set routing-instances {{ instance_name | default("VPLS-1") }} route-distinguisher {{ rd | default("") }}
set routing-instances {{ instance_name | default("VPLS-1") }} vrf-target target:{{ rt | default("") }}
{% for peer in peers | default([]) %}
set routing-instances {{ instance_name | default("VPLS-1") }} protocols vpls neighbor {{ peer.ip }}
{% endfor %}
{% if site_id | default("") %}
set routing-instances {{ instance_name | default("VPLS-1") }} protocols vpls site {{ site_name | default("SITE-1") }} site-identifier {{ site_id }}
{% endif %}

{# route_redistribution.j2 — junos #}
! Route Redistribution
! Intent: {{ intent_id }}
!
{% for source in sources | default([]) %}
set policy-options policy-statement {{ policy_name | default("REDISTRIBUTE") }} term {{ source.protocol }} from protocol {{ source.protocol }}
set policy-options policy-statement {{ policy_name | default("REDISTRIBUTE") }} term {{ source.protocol }} then accept
{% endfor %}
{% if target_protocol | default("") == "ospf" %}
set protocols ospf export {{ policy_name | default("REDISTRIBUTE") }}
{% elif target_protocol | default("") == "bgp" %}
set protocols bgp group {{ bgp_group | default("EBGP") }} export {{ policy_name | default("REDISTRIBUTE") }}
{% elif target_protocol | default("") == "isis" %}
set protocols isis export {{ policy_name | default("REDISTRIBUTE") }}
{% endif %}

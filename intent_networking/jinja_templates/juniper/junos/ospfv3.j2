{# ospfv3.j2 — junos #}
! OSPFv3 Configuration
! Intent: {{ intent_id }}
!
{% if router_id | default("") %}
set routing-options router-id {{ router_id }}
{% endif %}
{% for iface in interfaces | default([]) %}
set protocols ospf3 area {{ iface.area | default("0.0.0.0") }} interface {{ iface.name }}
{% endfor %}

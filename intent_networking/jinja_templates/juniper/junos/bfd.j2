{# bfd.j2 — junos #}
! BFD Configuration
! Intent: {{ intent_id }}
!
{% for iface in interfaces | default([]) %}
set protocols ospf area {{ iface.area | default("0.0.0.0") }} interface {{ iface.name }} bfd-liveness-detection minimum-interval {{ iface.interval | default(300) }}
set protocols ospf area {{ iface.area | default("0.0.0.0") }} interface {{ iface.name }} bfd-liveness-detection multiplier {{ iface.multiplier | default(3) }}
{% endfor %}

{# aaa.j2 — junos #}
! AAA Configuration
! Intent: {{ intent_id }}
!
{% for method in authentication_methods | default(["tacplus", "password"]) %}
{% endfor %}
set system authentication-order [ {{ authentication_methods | default(["tacplus", "password"]) | join(" ") }} ]
{% if accounting | default(false) %}
set system accounting events login
set system accounting events change-log
{% endif %}
{% if authorization | default(false) %}
set system services ssh
{% endif %}

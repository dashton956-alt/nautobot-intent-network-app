{# pbr.j2 — junos #}
! Filter-Based Forwarding (PBR)
! Intent: {{ intent_id }}
!
{% for entry in entries | default([]) %}
set firewall family inet filter {{ route_map_name | default("PBR-FILTER") }} term {{ entry.name | default("TERM-" ~ loop.index) }} from source-address {{ entry.source | default("0.0.0.0/0") }}
{% if entry.set_next_hop | default("") %}
set firewall family inet filter {{ route_map_name | default("PBR-FILTER") }} term {{ entry.name | default("TERM-" ~ loop.index) }} then routing-instance {{ entry.routing_instance | default("PBR-RI") }}
set routing-instances {{ entry.routing_instance | default("PBR-RI") }} routing-options static route 0.0.0.0/0 next-hop {{ entry.set_next_hop }}
{% endif %}
{% endfor %}
{% for iface in apply_interfaces | default([]) %}
set interfaces {{ iface }} unit 0 family inet filter input {{ route_map_name | default("PBR-FILTER") }}
{% endfor %}

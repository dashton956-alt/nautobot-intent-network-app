{# pseudowire.j2 — junos #}
! Pseudowire
! Intent: {{ intent_id }}
!
set protocols l2circuit neighbor {{ peer_ip }} interface {{ attachment_circuit | default("") }} virtual-circuit-id {{ vc_id }}
{% if mtu | default("") %}
set protocols l2circuit neighbor {{ peer_ip }} interface {{ attachment_circuit | default("") }} mtu {{ mtu }}
{% endif %}

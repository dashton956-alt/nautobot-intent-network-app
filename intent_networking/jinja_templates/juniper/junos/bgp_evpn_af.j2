{# bgp_evpn_af.j2 — junos #}
! BGP EVPN Address Family
! Intent: {{ intent_id }}
!
{% for neighbor in neighbors | default([]) %}
set protocols bgp group EVPN-OVERLAY neighbor {{ neighbor.ip }}
set protocols bgp group EVPN-OVERLAY neighbor {{ neighbor.ip }} peer-as {{ neighbor.remote_as | default(local_asn) }}
{% endfor %}
set protocols bgp group EVPN-OVERLAY type internal
set protocols bgp group EVPN-OVERLAY local-address {{ local_address | default("") }}
set protocols bgp group EVPN-OVERLAY family evpn signaling
{% for neighbor in neighbors | default([]) %}
{% if neighbor.route_reflector_client | default(false) %}
set protocols bgp group EVPN-OVERLAY neighbor {{ neighbor.ip }} cluster {{ cluster_id | default(router_id | default("")) }}
{% endif %}
{% endfor %}

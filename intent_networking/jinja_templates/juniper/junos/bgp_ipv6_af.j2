{# bgp_ipv6_af.j2 — junos #}
! BGP IPv6 Address Family
! Intent: {{ intent_id }}
!
{% for neighbor in neighbors | default([]) %}
set protocols bgp group {{ bgp_group | default("IPv6-PEERS") }} neighbor {{ neighbor.ip }} family inet6 unicast
{% if neighbor.route_policy_in | default("") %}
set protocols bgp group {{ bgp_group | default("IPv6-PEERS") }} neighbor {{ neighbor.ip }} import {{ neighbor.route_policy_in }}
{% endif %}
{% if neighbor.route_policy_out | default("") %}
set protocols bgp group {{ bgp_group | default("IPv6-PEERS") }} neighbor {{ neighbor.ip }} export {{ neighbor.route_policy_out }}
{% endif %}
{% endfor %}

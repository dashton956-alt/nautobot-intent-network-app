{# dot1x.j2 — junos #}
! 802.1X Authentication
! Intent: {{ intent_id }}
!
{% for iface in interfaces | default([]) %}
set protocols dot1x authenticator interface {{ iface.name }}
{% if iface.mac_radius | default(false) %}
set protocols dot1x authenticator interface {{ iface.name }} mac-radius
{% endif %}
{% if iface.guest_vlan | default("") %}
set protocols dot1x authenticator interface {{ iface.name }} guest-vlan {{ iface.guest_vlan }}
{% endif %}
{% if iface.reauthentication | default("") %}
set protocols dot1x authenticator interface {{ iface.name }} reauthentication {{ iface.reauthentication }}
{% endif %}
{% endfor %}

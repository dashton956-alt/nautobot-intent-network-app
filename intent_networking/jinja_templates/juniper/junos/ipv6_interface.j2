{# ipv6_interface.j2 — junos #}
! IPv6 Interface
! Intent: {{ intent_id }}
!
set interfaces {{ interface }} unit 0 family inet6 address {{ ipv6_address }}
{% if link_local | default("") %}
set interfaces {{ interface }} unit 0 family inet6 address {{ link_local }}
{% endif %}
{% if description | default("") %}
set interfaces {{ interface }} description "{{ description }}"
{% endif %}

{# ipv6_interface.j2 — junos #}
! IPv6 Interface
! Intent: {{ intent_id }}
!
{% for iface in interfaces | default([]) %}
{% if iface.ipv6_address is defined and iface.ipv6_address %}
set interfaces {{ iface.name }} unit 0 family inet6 address {{ iface.ipv6_address }}
{% endif %}
{% if iface.link_local is defined and iface.link_local %}
set interfaces {{ iface.name }} unit 0 family inet6 address {{ iface.link_local }}
{% endif %}
{% endfor %}

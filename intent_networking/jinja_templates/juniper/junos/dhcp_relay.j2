{# dhcp_relay.j2 — junos #}
! DHCP Relay
! Intent: {{ intent_id }}
!
{% for server in servers | default([]) %}
set forwarding-options dhcp-relay server-group DHCP-SERVERS {{ server }}
{% endfor %}
{% for iface in interfaces | default([]) %}
set forwarding-options dhcp-relay group RELAY interface {{ iface }}
{% endfor %}
set forwarding-options dhcp-relay group RELAY active-server-group DHCP-SERVERS

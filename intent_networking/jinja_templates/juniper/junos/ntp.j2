{# ntp.j2 — junos #}
! NTP Configuration
! Intent: {{ intent_id }}
!
{% for server in servers | default([]) %}
set system ntp server {{ server.ip }}
{% if server.prefer | default(false) %}
set system ntp server {{ server.ip }} prefer
{% endif %}
{% endfor %}
{% if source_address | default("") %}
set system ntp source-address {{ source_address }}
{% endif %}

{# loopback.j2 — junos #}
! Loopback Interface
! Intent: {{ intent_id }}
!
set interfaces lo0 unit {{ unit | default(0) }} family inet address {{ ip_address }}/32
{% if description | default("") %}
set interfaces lo0 unit {{ unit | default(0) }} description "{{ description }}"
{% endif %}
{% if vrf | default("") %}
set routing-instances {{ vrf }} interface lo0.{{ unit | default(0) }}
{% endif %}

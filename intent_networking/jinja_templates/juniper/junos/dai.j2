{# dai.j2 — junos #}
! Dynamic ARP Inspection
! Intent: {{ intent_id }}
!
{% for vlan_item in vlans | default([]) %}
set vlans VLAN{{ vlan_item }} forwarding-options dhcp-security arp-inspection
{% endfor %}
{% for iface in trusted_interfaces | default([]) %}
set ethernet-switching-options secure-access-port interface {{ iface }} no-dhcp-trusted
{% endfor %}

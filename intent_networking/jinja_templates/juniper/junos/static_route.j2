{# static_route.j2 — junos #}
! Static Routes
! Intent: {{ intent_id }}
!
{% for route in routes | default([]) %}
{% if route.vrf | default("") %}
set routing-instances {{ route.vrf }} routing-options static route {{ route.prefix }} next-hop {{ route.next_hop }}
{% if route.preference | default("") %}
set routing-instances {{ route.vrf }} routing-options static route {{ route.prefix }} preference {{ route.preference }}
{% endif %}
{% else %}
set routing-options static route {{ route.prefix }} next-hop {{ route.next_hop }}
{% if route.preference | default("") %}
set routing-options static route {{ route.prefix }} preference {{ route.preference }}
{% endif %}
{% endif %}
{% endfor %}

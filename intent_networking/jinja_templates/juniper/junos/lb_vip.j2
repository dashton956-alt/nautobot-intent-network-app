{# lb_vip.j2 — junos #}
! Load Balancer VIP (SLB)
! Intent: {{ intent_id }}
!
{% for vip in vips | default([]) %}
set services stateful-firewall rule {{ vip.name | default("LB-VIP") }} match-direction input
set services stateful-firewall rule {{ vip.name | default("LB-VIP") }} term 1 from destination-address {{ vip.address }}
set services stateful-firewall rule {{ vip.name | default("LB-VIP") }} term 1 then accept
{% endfor %}

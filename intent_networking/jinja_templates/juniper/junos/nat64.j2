{# nat64.j2 — junos #}
! NAT64
! Intent: {{ intent_id }}
!
set services nat64 stateful-nat64 nat64-prefix {{ nat64_prefix | default("64:ff9b::/96") }}
{% for rule in rules | default([]) %}
set services nat64 stateful-nat64 pool {{ rule.pool_name | default("NAT64-POOL") }} address {{ rule.address }}
{% endfor %}

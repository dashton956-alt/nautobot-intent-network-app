{# mgmt_interface.j2 — junos #}
! Management Interface
! Intent: {{ intent_id }}
!
set interfaces {{ interface | default("fxp0") }} unit 0 family inet address {{ ip_address }}/{{ prefix_len | default(24) }}
{% if description | default("") %}
set interfaces {{ interface | default("fxp0") }} description "{{ description }}"
{% endif %}
{% if gateway | default("") %}
set routing-options static route 0.0.0.0/0 next-hop {{ gateway }}
{% endif %}
{% if vrf | default("") %}
set routing-instances {{ vrf }} interface {{ interface | default("fxp0") }}.0
{% endif %}

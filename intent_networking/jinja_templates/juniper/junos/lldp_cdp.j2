{# lldp_cdp.j2 — junos #}
! LLDP Configuration
! Intent: {{ intent_id }}
!
{% if lldp_enabled | default(true) %}
set protocols lldp
{% else %}
delete protocols lldp
{% endif %}
{% for iface in interfaces | default([]) %}
{% if iface.lldp_disable | default(false) %}
set protocols lldp interface {{ iface.name }} disable
{% else %}
set protocols lldp interface {{ iface.name }}
{% endif %}
{% endfor %}
{% if management_address | default("") %}
set protocols lldp management-address {{ management_address }}
{% endif %}

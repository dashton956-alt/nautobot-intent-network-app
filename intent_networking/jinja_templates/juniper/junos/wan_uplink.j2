{# wan_uplink.j2 — junos #}
! WAN Uplink
! Intent: {{ intent_id }}
!
set interfaces {{ interface }} unit 0 family inet address {{ ip_address }}/{{ prefix_len | default(30) }}
{% if description | default("") %}
set interfaces {{ interface }} description "{{ description }}"
{% endif %}
{% if bandwidth | default("") %}
set interfaces {{ interface }} speed {{ bandwidth }}
{% endif %}
{% if mtu | default("") %}
set interfaces {{ interface }} mtu {{ mtu }}
{% endif %}
{% if vrf | default("") %}
set routing-instances {{ vrf }} interface {{ interface }}.0
{% endif %}

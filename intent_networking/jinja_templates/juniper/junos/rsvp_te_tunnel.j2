{# rsvp_te_tunnel.j2 — junos #}
! RSVP-TE Tunnel
! Intent: {{ intent_id }}
!
{% for iface in interfaces | default([]) %}
set protocols rsvp interface {{ iface }}
set protocols mpls interface {{ iface }}
{% endfor %}
set protocols mpls label-switched-path {{ lsp_name | default("LSP-" ~ tunnel_id) }} to {{ destination }}
{% if tunnel_bandwidth | default("") %}
set protocols mpls label-switched-path {{ lsp_name | default("LSP-" ~ tunnel_id) }} bandwidth {{ tunnel_bandwidth }}
{% endif %}
{% if explicit_path | default("") %}
set protocols mpls label-switched-path {{ lsp_name | default("LSP-" ~ tunnel_id) }} primary {{ explicit_path }}
{% endif %}

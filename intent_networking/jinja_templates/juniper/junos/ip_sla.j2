{# ip_sla.j2 — junos #}
! RPM (IP SLA equivalent)
! Intent: {{ intent_id }}
!
{% for probe in probes | default([]) %}
set services rpm probe {{ probe.name | default("SLA-" ~ loop.index) }} test {{ probe.test_name | default("ICMP-TEST") }} probe-type icmp-ping
set services rpm probe {{ probe.name | default("SLA-" ~ loop.index) }} test {{ probe.test_name | default("ICMP-TEST") }} target address {{ probe.target }}
set services rpm probe {{ probe.name | default("SLA-" ~ loop.index) }} test {{ probe.test_name | default("ICMP-TEST") }} probe-interval {{ probe.frequency | default(60) }}
set services rpm probe {{ probe.name | default("SLA-" ~ loop.index) }} test {{ probe.test_name | default("ICMP-TEST") }} probe-count {{ probe.count | default(5) }}
{% if probe.threshold | default("") %}
set services rpm probe {{ probe.name | default("SLA-" ~ loop.index) }} test {{ probe.test_name | default("ICMP-TEST") }} thresholds successive-loss {{ probe.threshold }}
{% endif %}
{% endfor %}

{# dhcp_snooping.j2 — junos #}
! DHCP Snooping (DHCP Security)
! Intent: {{ intent_id }}
!
{% for vlan_item in vlans | default([]) %}
set vlans VLAN{{ vlan_item }} forwarding-options dhcp-security
{% endfor %}
{% for iface in trusted_interfaces | default([]) %}
set vlans {{ vlan_name | default("default") }} forwarding-options dhcp-security group TRUSTED interface {{ iface }}
{% endfor %}

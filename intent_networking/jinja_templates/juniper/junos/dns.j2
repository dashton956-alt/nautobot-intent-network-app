{# dns.j2 — junos #}
! DNS Configuration
! Intent: {{ intent_id }}
!
{% for server in servers | default([]) %}
set system name-server {{ server }}
{% endfor %}
{% if domain_name | default("") %}
set system domain-name {{ domain_name }}
{% endif %}
{% for domain in search_domains | default([]) %}
set system domain-search {{ domain }}
{% endfor %}

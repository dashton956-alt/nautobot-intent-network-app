{# zbf_removal.j2 — arista-eos #}
! Remove Zone-Based Firewall Configuration
! Intent: {{ intent_id }}
!
{% for zp in zone_pairs | default([]) %}
no security zone-pair {{ zp.source }}-to-{{ zp.destination }}
!
{% endfor %}
{% for cm in class_maps | default([]) %}
traffic-policies
   no traffic-policy INTENT-{{ cm.name }}
!
{% endfor %}
{% for zone in zones | default([]) %}
no security zone {{ zone.name }}
!
{% endfor %}

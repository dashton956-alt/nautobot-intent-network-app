{# netconf.j2 — arista-eos #}
! NETCONF / RESTCONF / gNMI Configuration
! Intent: {{ intent_id }}
!
{% if netconf_enabled is not defined or netconf_enabled %}
management api netconf
   transport ssh default
{% if vrf %}
      vrf {{ vrf }}
{% endif %}
{% if port %}
      port {{ port }}
{% endif %}
   no shutdown
{% else %}
no management api netconf
{% endif %}
!
{% if enable_restconf %}
management api http-commands
   protocol https
{% if restconf_port %}
   port {{ restconf_port }}
{% endif %}
   no shutdown
{% if restconf_vrf %}
   vrf {{ restconf_vrf }}
{% endif %}
{% endif %}
!
{% if gnmi_enabled %}
management api gnmi
   transport grpc default
{% if gnmi_port %}
      port {{ gnmi_port }}
{% endif %}
   provider eos-native
!
{% endif %}

{# nat.j2 — arista-eos #}
! NAT / PAT Configuration
! Intent: {{ intent_id }}
!
{% if nat_type == "static" %}
{% for mapping in static_mappings | default([]) %}
ip nat source static {{ mapping.inside }} {{ mapping.outside }}{% if mapping.vrf | default("") %} vrf {{ mapping.vrf }}{% endif %}

{% endfor %}
{% elif nat_type == "dynamic" %}
{% if pool_name %}
ip nat pool {{ pool_name }} {{ pool_start }} {{ pool_end }} prefix-length {{ prefix_length | default(24) }}
{% endif %}
{% if acl %}
ip nat source list {{ acl }} pool {{ pool_name }}{% if overload %} overload{% endif %}

{% endif %}
{% elif nat_type == "pat" or nat_type == "overload" %}
{% if acl %}
ip nat source list {{ acl }} interface {{ outside_interface }} overload
{% endif %}
{% endif %}
!
{% if inside_interface %}
interface {{ inside_interface }}
   ip nat inside
!
{% endif %}
{% if outside_interface %}
interface {{ outside_interface }}
   ip nat outside
!
{% endif %}

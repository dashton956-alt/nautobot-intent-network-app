{# copp.j2 — arista-eos #}
! Control Plane Policing Configuration
! Intent: {{ intent_id }}
!
{% for cls in classes | default([]) %}
ip access-list {{ cls.acl_name }}
{% for rule in cls.rules | default([]) %}
   {{ rule.seq | default(loop.index * 10) }} {{ rule.action }} {{ rule.protocol }} {{ rule.source | default("any") }} {{ rule.destination | default("any") }}{% if rule.port %} eq {{ rule.port }}{% endif %}

{% endfor %}
!
{% endfor %}
system control-plane
{% for cls in classes | default([]) %}
   ip access-group {{ cls.acl_name }} in
{% endfor %}
!

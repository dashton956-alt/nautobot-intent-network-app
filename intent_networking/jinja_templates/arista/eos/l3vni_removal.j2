{# l3vni_removal.j2 — arista-eos #}
! Remove L3 VNI Configuration
! Intent: {{ intent_id }}
!
router bgp {{ bgp_asn | default(65000) }}
   no vrf {{ vrf_name }}
!
interface Vxlan1
   no vxlan vrf {{ vrf_name }} vni
!
{% if vlan_id %}
no interface Vlan{{ vlan_id }}
no vlan {{ vlan_id }}
{% endif %}
no vrf instance {{ vrf_name }}
!

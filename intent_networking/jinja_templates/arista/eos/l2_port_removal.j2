{# l2_port_removal.j2 — arista-eos #}
! Remove Layer 2 Port Configuration — {{ interface }}
! Intent: {{ intent_id }}
!
interface {{ interface }}
   no description
   no switchport mode
   no switchport access vlan
   no switchport trunk allowed vlan
{% if voice_vlan %}
   no switchport voice vlan
{% endif %}
   no spanning-tree portfast
   no spanning-tree bpduguard
!

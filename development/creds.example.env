################################################################################
# CREDS File: Store private information. Copied to creds.env and always ignored
#
# WARNING: This is an EXAMPLE file only. ALL placeholder values below MUST be
# replaced with strong, unique credentials before use in any environment.
# DO NOT use this file as-is in production, staging, or any environment
# connected to real infrastructure.
################################################################################
# Nautobot Configuration Secret Items
NAUTOBOT_CREATE_SUPERUSER=true
NAUTOBOT_DB_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>
NAUTOBOT_NAPALM_USERNAME=''
NAUTOBOT_NAPALM_PASSWORD=''
NAUTOBOT_REDIS_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>
NAUTOBOT_SECRET_KEY=<REPLACE_WITH_RANDOM_SECRET_KEY>
NAUTOBOT_SUPERUSER_NAME=admin
NAUTOBOT_SUPERUSER_EMAIL=admin@example.com
NAUTOBOT_SUPERUSER_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>
NAUTOBOT_SUPERUSER_API_TOKEN=<REPLACE_WITH_GENERATED_API_TOKEN>

# Postgres
POSTGRES_PASSWORD=${NAUTOBOT_DB_PASSWORD}
PGPASSWORD=${NAUTOBOT_DB_PASSWORD}

# MySQL Credentials
MYSQL_ROOT_PASSWORD=${NAUTOBOT_DB_PASSWORD}
MYSQL_PASSWORD=${NAUTOBOT_DB_PASSWORD}

# GitHub Personal Access Token for issue creation on drift detection
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Use these to override values in development.env
# NAUTOBOT_DB_HOST=localhost
# NAUTOBOT_REDIS_HOST=localhost
# NAUTOBOT_CONFIG=development/nautobot_config.py

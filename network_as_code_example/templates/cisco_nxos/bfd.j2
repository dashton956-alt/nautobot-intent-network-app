{# bfd — Cisco NX-OS Bidirectional Forwarding Detection configuration #}
feature bfd

{% for intf in bfd_interfaces | default([]) %}
interface {{ intf.name }}
 bfd interval {{ intf.interval | default(300) }} min_rx {{ intf.min_rx | default(300) }} multiplier {{ intf.multiplier | default(3) }}
{% if intf.echo | default(false) %}
 bfd echo
{% else %}
 no bfd echo
{% endif %}
{% endfor %}

{# bgp_evpn_af — Cisco NX-OS BGP EVPN address-family configuration #}
router bgp {{ local_as }}
 router-id {{ router_id }}
 log-neighbor-changes
{% for neighbor in evpn_neighbors | default([]) %}
 neighbor {{ neighbor.ip }}
  remote-as {{ neighbor.remote_as | default(local_as) }}
  description {{ neighbor.description | default('EVPN neighbor') }}
  update-source {{ neighbor.update_source | default('loopback0') }}
  address-family l2vpn evpn
   send-community
   send-community extended
{% if neighbor.rr_client | default(false) %}
   route-reflector-client
{% endif %}
{% if neighbor.next_hop_unchanged | default(false) %}
   next-hop-unchanged
{% endif %}
{% endfor %}

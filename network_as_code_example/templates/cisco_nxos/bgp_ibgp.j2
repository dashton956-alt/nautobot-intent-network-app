{# bgp_ibgp — Cisco NX-OS iBGP configuration #}
feature bgp

router bgp {{ local_as }}
 router-id {{ router_id }}
 log-neighbor-changes
{% for neighbor in ibgp_neighbors | default([]) %}
 neighbor {{ neighbor.ip }}
  remote-as {{ local_as }}
  description {{ neighbor.description | default('iBGP peer') }}
  update-source {{ update_source | default('loopback0') }}
  address-family ipv4 unicast
   send-community
   send-community extended
{% if neighbor.rr_client | default(false) %}
   route-reflector-client
{% endif %}
{% if neighbor.next_hop_self | default(false) %}
   next-hop-self
{% endif %}
{% endfor %}

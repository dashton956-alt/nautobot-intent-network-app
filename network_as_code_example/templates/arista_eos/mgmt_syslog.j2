{# mgmt_syslog — Arista EOS syslog configuration #}
{% if syslog_source_interface is defined and syslog_source_interface %}
logging source-interface {{ syslog_source_interface }}
{% endif %}
{% if syslog_trap_level is defined and syslog_trap_level %}
logging trap {{ syslog_trap_level }}
{% endif %}
logging on

{% for server in syslog_servers | default([]) %}
{% if server.protocol | default('udp') == 'tcp' %}
logging host {{ server.host }} {{ server.port | default(514) }} protocol tcp
{% else %}
logging host {{ server.host }} {{ server.port | default(514) }}
{% endif %}
{% endfor %}

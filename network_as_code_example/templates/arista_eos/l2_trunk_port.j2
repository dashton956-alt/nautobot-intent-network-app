{# l2_trunk_port — Arista EOS trunk port configuration #}
interface {{ interface }}
{% if description is defined and description %}
   description {{ description }}
{% endif %}
   switchport mode trunk
{% if native_vlan is defined and native_vlan %}
   switchport trunk native vlan {{ native_vlan }}
{% endif %}
{% if allowed_vlans is defined and allowed_vlans %}
   switchport trunk allowed vlan {{ allowed_vlans }}
{% endif %}
{% if trunk_groups is defined and trunk_groups %}
{% for tg in trunk_groups %}
   switchport trunk group {{ tg }}
{% endfor %}
{% endif %}
{% if portfast is defined and portfast %}
   spanning-tree portfast trunk
{% endif %}
{% if bpdu_guard is defined and bpdu_guard %}
   spanning-tree bpduguard enable
{% endif %}
{% if mtu is defined and mtu %}
   mtu {{ mtu }}
{% endif %}
{% if shutdown | default(false) %}
   shutdown
{% else %}
   no shutdown
{% endif %}

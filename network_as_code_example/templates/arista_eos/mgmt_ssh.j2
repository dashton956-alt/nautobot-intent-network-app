{# mgmt_ssh — Arista EOS SSHv2 configuration #}
{# WARNING: Do NOT use fail_action: rollback for SSH changes — can lock out access #}
ip ssh version 2

{% if ssh_timeout is defined and ssh_timeout %}
ip ssh timeout {{ ssh_timeout }}
{% endif %}

{% if ssh_max_sessions is defined and ssh_max_sessions %}
ip ssh max-session {{ ssh_max_sessions }}
{% endif %}

{% if ssh_ciphers is defined %}
{% if ssh_ciphers.kex is defined and ssh_ciphers.kex %}
ip ssh kex-algorithm {% for kex in ssh_ciphers.kex %}{{ kex }}{% if not loop.last %} {% endif %}{% endfor %}

{% endif %}
{% if ssh_ciphers.ciphers is defined and ssh_ciphers.ciphers %}
ip ssh cipher {% for c in ssh_ciphers.ciphers %}{{ c }}{% if not loop.last %} {% endif %}{% endfor %}

{% endif %}
{% if ssh_ciphers.macs is defined and ssh_ciphers.macs %}
ip ssh mac {% for mac in ssh_ciphers.macs %}{{ mac }}{% if not loop.last %} {% endif %}{% endfor %}

{% endif %}
{% endif %}

{% if ssh_allowed_prefixes is defined and ssh_allowed_prefixes %}
ip access-list standard ACL-SSH-MGMT
{% for prefix in ssh_allowed_prefixes %}
   permit {{ prefix }}
{% endfor %}
   deny any log
{% endif %}

{% if vty_lines is defined %}
line vty {{ vty_lines.first | default(0) }} {{ vty_lines.last | default(4) }}
   transport input {{ vty_lines.transport_input | default('ssh') }}
{% if vty_lines.exec_timeout_minutes is defined %}
   exec-timeout {{ vty_lines.exec_timeout_minutes }} {{ vty_lines.exec_timeout_seconds | default(0) }}
{% endif %}
{% if ssh_allowed_prefixes is defined and ssh_allowed_prefixes %}
   access-class ACL-SSH-MGMT in
{% endif %}
{% if vty_lines.access_class is defined and vty_lines.access_class %}
   access-class {{ vty_lines.access_class }} in
{% endif %}
   login authentication default
{% endif %}

{# dhcp_snooping — Cisco IOS-XE DHCP snooping configuration #}
ip dhcp snooping
{% for vlan_range in snooping_vlans | default([]) %}
ip dhcp snooping vlan {{ vlan_range }}
{% endfor %}
{% if arp_validation | default(false) %}
ip dhcp snooping verify mac-address
{% endif %}
{% for intf in trusted_interfaces | default([]) %}
interface {{ intf }}
 ip dhcp snooping trust
{% endfor %}
{% for intf in rate_limit_interfaces | default([]) %}
interface {{ intf.name }}
 ip dhcp snooping limit rate {{ intf.rate }}
{% endfor %}

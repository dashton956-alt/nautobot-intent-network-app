{# vlan_provision — Cisco IOS-XE VLAN and SVI provisioning #}
{% for vlan in vlans %}
vlan {{ vlan.id }}
 name {{ vlan.name }}
{% endfor %}

{% for vlan in vlans %}
{% if vlan.ip_address is defined and vlan.ip_address %}
interface Vlan{{ vlan.id }}
 description {{ vlan.description | default(vlan.name) }}
{% if vlan.vrf is defined and vlan.vrf %}
 ip vrf forwarding {{ vlan.vrf }}
{% endif %}
 ip address {{ vlan.ip_address | replace('/', ' ') }}
{% if vlan.ipv6_address is defined and vlan.ipv6_address %}
 ipv6 address {{ vlan.ipv6_address }}
{% endif %}
 no shutdown
{% endif %}
{% endfor %}

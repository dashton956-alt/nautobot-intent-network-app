{# reachability_ip_sla — Cisco IOS-XE IP SLA probe configuration #}
{% for probe in probes | default([]) %}
ip sla {{ probe.id }}
{% if probe.type | default('icmp-echo') == 'icmp-echo' %}
 icmp-echo {{ probe.destination }}{% if probe.source_interface is defined %} source-interface {{ probe.source_interface }}{% endif %}

{% elif probe.type == 'tcp-connect' %}
 tcp-connect {{ probe.destination }} {{ probe.destination_port | default(80) }}{% if probe.source_interface is defined %} source-interface {{ probe.source_interface }}{% endif %}

{% endif %}
{% if probe.threshold is defined %}
 threshold {{ probe.threshold }}
{% endif %}
{% if probe.timeout is defined %}
 timeout {{ probe.timeout }}
{% endif %}
{% if probe.frequency is defined %}
 frequency {{ probe.frequency }}
{% endif %}
ip sla schedule {{ probe.id }} life forever start-time now
{% if probe.track_id is defined %}
track {{ probe.track_id }} ip sla {{ probe.id }} reachability
{% endif %}
{% endfor %}

{# mgmt_ntp — Cisco IOS-XE NTP configuration #}
{% if timezone is defined and timezone %}
clock timezone {{ timezone }} {{ timezone_offset | default(0) }}
{% endif %}

{% if authenticate | default(false) %}
ntp authenticate
ntp authentication-key {{ auth_key_id }} md5 {{ auth_key }}
ntp trusted-key {{ auth_key_id }}
{% endif %}

{% for server in ntp_servers | default([]) %}
ntp server {{ server }}{% if authenticate | default(false) %} key {{ auth_key_id }}{% endif %}{% if ntp_source_interface is defined %} source {{ ntp_source_interface }}{% endif %}

{% endfor %}

{% if ntp_access_group is defined and ntp_access_group %}
ntp access-group serve {{ ntp_access_group }}
{% endif %}

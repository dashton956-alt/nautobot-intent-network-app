{# mgmt_dhcp_server — Cisco IOS-XE DHCP server pool configuration #}
{% for excl in excluded_addresses | default([]) %}
ip dhcp excluded-address {{ excl.start }} {{ excl.end }}
{% endfor %}

{% for pool in pools | default([]) %}
ip dhcp pool {{ pool.name }}
 network {{ pool.network | replace('/', ' ') }}
 default-router {{ pool.default_router }}
{% if pool.dns_servers is defined %}
 dns-server {{ pool.dns_servers | join(' ') }}
{% endif %}
{% if pool.domain_name is defined and pool.domain_name %}
 domain-name {{ pool.domain_name }}
{% endif %}
{% if pool.lease_time is defined %}
 lease {{ (pool.lease_time / 86400) | int }} {{ ((pool.lease_time % 86400) / 3600) | int }} {{ ((pool.lease_time % 3600) / 60) | int }}
{% elif lease_time is defined %}
 lease {{ (lease_time / 86400) | int }} {{ ((lease_time % 86400) / 3600) | int }} {{ ((lease_time % 3600) / 60) | int }}
{% endif %}
{% endfor %}

{# ipsec_ikev2 — Cisco IOS-XE IKEv2 IPSec configuration #}
crypto ikev2 proposal {{ proposal_name | default('IKEV2-PROPOSAL') }}
 encryption {{ encryption | default('aes-cbc-256') }}
 integrity {{ integrity | default('sha256') }}
 group {{ dh_group | default(14) }}
{% if prf is defined and prf %}
 prf {{ prf }}
{% endif %}

crypto ikev2 policy {{ policy_map | default('IKEV2-POLICY') }}
 proposal {{ proposal_name | default('IKEV2-PROPOSAL') }}

{% if auth_method | default('psk') == 'psk' %}
crypto ikev2 keyring {{ keyring_name | default('IKEV2-KEYRING') }}
 peer REMOTE
  address {{ remote_peer }}
  pre-shared-key {{ psk | default('') }}

{% endif %}
crypto ikev2 profile {{ profile_name | default('IKEV2-PROFILE') }}
 match identity remote address {{ remote_peer }} 255.255.255.255
 authentication remote {{ auth_method | default('pre-share') }}
 authentication local {{ auth_method | default('pre-share') }}
 keyring local {{ keyring_name | default('IKEV2-KEYRING') }}
{% if dpd_interval is defined and dpd_interval %}
 dpd {{ dpd_interval }} {{ dpd_retry | default(2) }} on-demand
{% endif %}

crypto ipsec transform-set TS-IKEv2 esp-{{ encryption | default('aes-256-gcm') }} esp-{{ integrity | default('sha256') }}-hmac
 mode tunnel

crypto ipsec profile {{ profile_name | default('IKEV2-IPSEC-PROFILE') }}
 set transform-set TS-IKEv2
 set ikev2-profile {{ profile_name | default('IKEV2-PROFILE') }}

interface Tunnel0
 description IPSec IKEv2 to {{ remote_peer }}
 tunnel source {{ local_endpoint | default('Loopback0') }}
 tunnel destination {{ remote_peer }}
 tunnel mode ipsec ipv4
 tunnel protection ipsec profile {{ profile_name | default('IKEV2-IPSEC-PROFILE') }}
 no shutdown

{# dai — Cisco IOS-XE Dynamic ARP Inspection configuration #}
{% for vlan_range in dai_vlans | default([]) %}
ip arp inspection vlan {{ vlan_range }}
{% endfor %}
{% if arp_acl is defined %}
ip arp inspection filter {{ arp_acl }} vlan {{ dai_vlans | default([]) | join(',') }}
{% endif %}
{% for intf in trusted_interfaces | default([]) %}
interface {{ intf }}
 ip arp inspection trust
{% endfor %}
{% if logging_enable | default(true) %}
ip arp inspection log-buffer entries {{ log_buffer_entries | default(32) }}
{% endif %}

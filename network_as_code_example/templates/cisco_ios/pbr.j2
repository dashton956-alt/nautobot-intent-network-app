{# pbr — Cisco IOS-XE Policy-Based Routing configuration #}
{% for clause in pbr_clauses | default([]) %}
route-map {{ pbr_map_name | default('PBR-MAP') }} permit {{ clause.seq }}
{% if clause.match_acl is defined %}
 match ip address {{ clause.match_acl }}
{% endif %}
{% if clause.set_nexthop is defined %}
 set ip next-hop {{ clause.set_nexthop }}
{% endif %}
{% if clause.set_interface is defined %}
 set interface {{ clause.set_interface }}
{% endif %}
{% if clause.set_default_nexthop is defined %}
 set ip default next-hop {{ clause.set_default_nexthop }}
{% endif %}
{% endfor %}
{% for intf in pbr_apply_interfaces | default([]) %}
interface {{ intf }}
 ip policy route-map {{ pbr_map_name | default('PBR-MAP') }}
{% endfor %}
